{% liquid
  assign enable_rtl = settings.enable_rtl

  assign body_classes = 'template-' | append: template.name

  if template.suffix != blank
    assign body_classes = body_classes | append: ' ' | append: template.suffix
  endif
%}

<!doctype html>
<html
  lang="{{ request.locale.iso_code }}"
  data-template="{{ template.name }}"
  {% if enable_rtl %}
    dir="rtl"
    class="rtl"
  {% endif %}
>
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="{{ settings.body_background }}">
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

    {% if settings.favicon != blank %}
      <link
        rel="shortcut icon"
        type="image/png"
        href="{{ settings.favicon | image_url: width: 32, height: 32 }}"
      >
    {% endif %}

    {% render 'css-variables' %}
    {% render 'cdn' %}

    {{ 'theme.css' | asset_url | stylesheet_tag: preload: true }}
    {{ 'product-card-style.css' | asset_url | stylesheet_tag }}

    {% render 'meta-tags' %}

    <script src="{{ 'theme.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'product-card.js' | asset_url }}" defer="defer"></script>
    {% if settings.enable_wishlist %}
      <script src="{{ 'wishlist.js' | asset_url }}" defer="defer"></script>
    {% endif %}
    

    {{ content_for_header }}
  </head>

  <body
    id="theme-noksha"
    class="{{ body_classes }}{% if enable_rtl %} rtl{% endif %} section-light"
    {% if template.name == 'product' %}
      data-product-id="{{ product.id }}"
    {% endif %}
  >
    {% sections 'header-group' %}

    {{ content_for_layout }}

    {% sections 'footer-group' %}
  </body>
</html>