{% render 'section-base-style' %}

{%- liquid
  assign classes = 'featured-showcase section-x-padding'
  assign classes = classes | append: ' section-' | append: section.id | append: '-padding'
  assign classes = classes | append: ' ' | append: section.settings.color_control
  assign classes = classes | append: ' m-color-' | append: section.settings.color_scheme
-%}

{% stylesheet %}
.featured-showcase {
  position: relative;
  overflow: hidden;
}

.featured-showcase__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: 90vh;
  align-items: center;
}

.featured-showcase__media {
  position: relative;
  height: 100%;
  overflow: hidden;
}

.featured-showcase__media img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.featured-showcase__content {
  padding: clamp(2rem, 6vw, 6rem);
  max-width: 40rem;
}

.featured-showcase__heading {
  margin-bottom: 1rem;
}

.featured-showcase__text {
  margin-bottom: 1.5rem;
}

@media (max-width: 991px){
  .featured-showcase__inner {
    grid-template-columns: 1fr;
  }

  .featured-showcase__media {
    height: 60vh;
  }
}
{% endstylesheet %}

<section 
  class="{{ classes }}"
  data-featured-showcase
  data-section-id="{{ section.id }}"
>
  <div class="featured-showcase__inner">

    <!-- IMAGE -->
    <div class="featured-showcase__media" data-showcase-image>
      {% render 'image',
        image: section.settings.image,
        class: 'cropped-image-wrapper cropped-image--portrait',
        img_alt: section.settings.heading
      %}
    </div>

    <!-- CONTENT -->
    <div class="featured-showcase__content">

      <h2 class="featured-showcase__heading {{ section.settings.heading_size }}" data-showcase-text>
        {{ section.settings.heading }}
      </h2>

      <div class="featured-showcase__text rte" data-showcase-text>
        {{ section.settings.text }}
      </div>

      {% if section.settings.button_label != blank %}
        <a href="{{ section.settings.button_link }}" class="btn btn-arrow" data-showcase-cta>
          <span>{{ section.settings.button_label }}</span>
          <span class="icon">{% render 'theme-icon', icon: 'right-arrow' %}</span>
        </a>
      {% endif %}

    </div>
  </div>
</section>

{% javascript %}
document.addEventListener('DOMContentLoaded', initFeaturedShowcase);
document.addEventListener('shopify:section:load', initFeaturedShowcase);

function initFeaturedShowcase() {
  if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;

  gsap.registerPlugin(ScrollTrigger);

  document.querySelectorAll('[data-featured-showcase]').forEach(section => {

    if (section.dataset.init === 'true') return;
    section.dataset.init = 'true';

    const image = section.querySelector('[data-showcase-image]');
    const texts = section.querySelectorAll('[data-showcase-text]');
    const cta = section.querySelector('[data-showcase-cta]');

    /* INITIAL STATES */
    gsap.set(image, { scale: 1.2 });
    gsap.set(texts, { opacity: 0, x: -40 });
    if (cta) gsap.set(cta, { opacity: 0, y: 20 });

    /* TIMELINE */
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: section,
        start: 'top top',
        end: '+=100%',
        scrub: true,
        pin: true
      }
    });

    /* IMAGE PARALLAX */
    tl.to(image, {
      scale: 1,
      y: -60,
      ease: 'none'
    }, 0);

    /* TEXT REVEAL */
    tl.to(texts, {
      opacity: 1,
      x: 0,
      stagger: 0.2,
      ease: 'power3.out'
    }, 0.2);

    /* CTA DELAYED */
    if (cta) {
      tl.to(cta, {
        opacity: 1,
        y: 0,
        ease: 'power3.out'
      }, 0.5);
    }

  });
}
{% endjavascript %}

{% schema %}
{
  "name": "Featured Showcase (GSAP)",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "New Collection"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        {"value":"h1","label":"H1"},
        {"value":"h2","label":"H2"},
        {"value":"h3","label":"H3"}
      ],
      "default": "h2"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Featured Showcase (GSAP)"
    }
  ]
}
{% endschema %}