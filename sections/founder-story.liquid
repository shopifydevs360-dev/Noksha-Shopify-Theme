{% render 'section-base-style' %}

{%- liquid
  assign section_classes = 'founder-story section-' | append: section.id | append: '-padding'
  assign section_classes = section_classes | append: ' m-color-' | append: section.settings.color_scheme
  assign section_classes = section_classes | append: ' ' | append: section.settings.custom_class
  assign section_classes = section_classes | append: ' ' | append: section.settings.color_control

  assign container_class = section.settings.container_width | default: 'container-fluid'
-%}

<section class="{{ section_classes }}" id="FounderStory-{{ section.id }}" {{ section.shopify_attributes }}>
  <div class="{{ container_class }}">
    <div class="sidebar-space">
      <div class="founder-story__inner founder-story__layout-{{ section.settings.layout_style }}">

        {% if section.settings.bg_text != blank %}
          <div class="founder-story__bg-text special-font-4">
            <span>{{ section.settings.bg_text }}</span>
          </div>
        {% endif %}

        <div class="founder-story__grid">

          <div class="founder-story__media founder-story__anim-media">
            <div class="founder-story__media-card border-radius-style-one">
              {% render 'image',
                image: section.settings.image,
                class: 'founder-story__image cropped-image-wrapper adapt-image-height',
                img_alt: section.settings.name,
                loading: 'lazy',
                fetchpriority: 'low'
              %}
            </div>

            {% if section.settings.image_caption != blank %}
              <div class="founder-story__image-caption founder-story__anim-fade">
                {{ section.settings.image_caption }}
              </div>
            {% endif %}
          </div>

          <div class="founder-story__content">
            {% if section.settings.eyebrow != blank %}
              <div class="founder-story__eyebrow founder-story__anim-fade">
                {{ section.settings.eyebrow }}
              </div>
            {% endif %}

            {% if section.settings.name != blank %}
              <h2 class="founder-story__title founder-story__anim-title">
                {{ section.settings.name }}
              </h2>
            {% endif %}

            {% if section.settings.designation != blank %}
              <div class="founder-story__designation founder-story__anim-fade">
                {{ section.settings.designation }}
              </div>
            {% endif %}

            {% if section.settings.short_intro != blank %}
              <div class="founder-story__intro founder-story__anim-fade rte">
                {{ section.settings.short_intro }}
              </div>
            {% endif %}

            {% if section.settings.description != blank %}
              <div class="founder-story__description founder-story__anim-text rte">
                {{ section.settings.description }}
              </div>
            {% endif %}

            {% if section.settings.signature_text != blank %}
              <div class="founder-story__signature founder-story__anim-fade special-font-3">
                {{ section.settings.signature_text }}
              </div>
            {% endif %}
          </div>

        </div>
      </div>
    </div>
  </div>
</section>

<style>
  #FounderStory-{{ section.id }} {
    position: relative;
    overflow: hidden;
    background: rgb(var(--color-background));
  }

  #FounderStory-{{ section.id }} .founder-story__inner {
    position: relative;
  }

  #FounderStory-{{ section.id }} .founder-story__grid {
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.4rem;
    align-items: center;
    z-index: 2;
  }

  #FounderStory-{{ section.id }} .founder-story__bg-text {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    overflow: hidden;
    pointer-events: none;
    z-index: 1;
  }

  #FounderStory-{{ section.id }} .founder-story__bg-text span {
    display: block;
    font-family: var(--font-custom-4, var(--font-heading-family, sans-serif));
    font-size: clamp(3.5rem, 12vw, {{ section.settings.bg_text_size }}px);
    line-height: 0.82;
    text-transform: uppercase;
    white-space: nowrap;
    letter-spacing: 0.04em;
    color: rgba(var(--color-additional-1), {{ section.settings.bg_text_opacity | divided_by: 100.0 }});
  }

  #FounderStory-{{ section.id }} .founder-story__media {
    position: relative;
    z-index: 2;
    max-width: min(100%, {{ section.settings.image_max_width }}px);
    margin: 0 auto;
  }

  #FounderStory-{{ section.id }} .founder-story__media-card {
    position: relative;
    overflow: hidden;
    background: rgba(var(--color-background-secondary), 1);
  }

  #FounderStory-{{ section.id }} .founder-story__image {
    display: block;
    width: 100%;
  }

  #FounderStory-{{ section.id }} .founder-story__image img,
  #FounderStory-{{ section.id }} .founder-story__image svg {
    width: 100%;
    height: auto;
    display: block;
  }

  #FounderStory-{{ section.id }} .founder-story__image-caption {
    margin-top: 0.9rem;
    font-size: 0.82rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(var(--color-subtext), 0.82);
    text-align: center;
  }

  #FounderStory-{{ section.id }} .founder-story__content {
    position: relative;
    z-index: 3;
    max-width: {{ section.settings.content_max_width }}px;
    margin: 0 auto;
  }

  #FounderStory-{{ section.id }} .founder-story__eyebrow {
    margin-bottom: 1rem;
    font-size: 0.82rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(var(--color-subtext), 0.9);
  }

  #FounderStory-{{ section.id }} .founder-story__title {
    margin: 0;
    font-size: clamp(2.4rem, 7vw, {{ section.settings.name_size }}px);
    line-height: 0.94;
    letter-spacing: -0.03em;
    color: rgb(var(--color-heading));
    max-width: 12ch;
  }

  #FounderStory-{{ section.id }} .founder-story__designation {
    margin-top: 1rem;
    margin-bottom: 1.3rem;
    font-size: 0.95rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(var(--color-subtext), 0.92);
  }

  #FounderStory-{{ section.id }} .founder-story__intro {
    margin-bottom: 1.5rem;
    color: rgb(var(--color-heading));
    font-size: clamp(1rem, 1.8vw, {{ section.settings.intro_size }}px);
    line-height: 1.65;
    max-width: 36em;
  }

  #FounderStory-{{ section.id }} .founder-story__description {
    color: rgb(var(--color-text));
    font-size: clamp(1rem, 1.35vw, {{ section.settings.body_size }}px);
    line-height: 1.9;
    max-width: 42em;
  }

  #FounderStory-{{ section.id }} .founder-story__description p + p {
    margin-top: 1.1rem;
  }

  #FounderStory-{{ section.id }} .founder-story__signature {
    margin-top: 1.8rem;
    font-size: clamp(1.15rem, 2vw, 2rem);
    color: rgb(var(--color-heading));
    opacity: 0.92;
  }

  @media (min-width: 992px) {
    #FounderStory-{{ section.id }} .founder-story__grid {
      grid-template-columns: minmax(340px, 0.82fr) minmax(460px, 1fr);
      gap: clamp(2rem, 5vw, 7rem);
      min-height: {{ section.settings.desktop_section_height }}vh;
      padding-top: 4rem;
    }

    #FounderStory-{{ section.id }} .founder-story__layout-image-right .founder-story__media {
      order: 2;
    }

    #FounderStory-{{ section.id }} .founder-story__layout-image-right .founder-story__content {
      order: 1;
    }

    #FounderStory-{{ section.id }} .founder-story__layout-image-left .founder-story__media {
      order: 1;
    }

    #FounderStory-{{ section.id }} .founder-story__layout-image-left .founder-story__content {
      order: 2;
    }

    #FounderStory-{{ section.id }} .founder-story__media {
      margin: 0;
    }

    #FounderStory-{{ section.id }} .founder-story__content {
      margin: 0;
    }

    #FounderStory-{{ section.id }} .founder-story__image-caption {
      text-align: left;
    }
  }

  @media (max-width: 991px) {
    #FounderStory-{{ section.id }} .founder-story__inner {
      padding-top: 1rem;
    }

    #FounderStory-{{ section.id }} .founder-story__bg-text {
      top: 0.2rem;
    }

    #FounderStory-{{ section.id }} .founder-story__bg-text span {
      font-size: clamp(2.7rem, 14vw, 5rem);
    }

    #FounderStory-{{ section.id }} .founder-story__media {
      max-width: min(100%, 560px);
    }

    #FounderStory-{{ section.id }} .founder-story__title {
      max-width: 100%;
    }
  }
</style>

<script>
  (function() {
    function initFounderStory(sectionId) {
      var section = document.getElementById('FounderStory-' + sectionId);
      if (!section) return;
      if (section.dataset.founderStoryInit === 'true') return;
      section.dataset.founderStoryInit = 'true';

      if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;

      gsap.registerPlugin(ScrollTrigger);

      var media = section.querySelector('.founder-story__anim-media');
      var title = section.querySelector('.founder-story__anim-title');
      var fades = section.querySelectorAll('.founder-story__anim-fade');
      var text = section.querySelector('.founder-story__anim-text');
      var bgText = section.querySelector('.founder-story__bg-text span');
      var image = section.querySelector('.founder-story__image img');

      if (bgText) {
        gsap.fromTo(bgText,
          {
            xPercent: -8,
            opacity: 0
          },
          {
            xPercent: 0,
            opacity: 1,
            duration: 1.3,
            ease: 'power3.out',
            scrollTrigger: {
              trigger: section,
              start: 'top 82%'
            }
          }
        );

        gsap.to(bgText, {
          xPercent: 8,
          ease: 'none',
          scrollTrigger: {
            trigger: section,
            start: 'top bottom',
            end: 'bottom top',
            scrub: 1.2
          }
        });
      }

      if (media) {
        gsap.fromTo(media,
          {
            y: 60,
            opacity: 0,
            scale: 0.97
          },
          {
            y: 0,
            opacity: 1,
            scale: 1,
            duration: 1.1,
            ease: 'power3.out',
            scrollTrigger: {
              trigger: media,
              start: 'top 82%'
            }
          }
        );
      }

      if (image) {
        gsap.to(image, {
          yPercent: -8,
          ease: 'none',
          scrollTrigger: {
            trigger: section,
            start: 'top bottom',
            end: 'bottom top',
            scrub: 1.4
          }
        });
      }

      if (title) {
        gsap.fromTo(title,
          {
            y: 45,
            opacity: 0
          },
          {
            y: 0,
            opacity: 1,
            duration: 1,
            ease: 'power3.out',
            scrollTrigger: {
              trigger: title,
              start: 'top 85%'
            }
          }
        );
      }

      if (fades.length) {
        gsap.fromTo(fades,
          {
            y: 26,
            opacity: 0
          },
          {
            y: 0,
            opacity: 1,
            duration: 0.9,
            stagger: 0.12,
            ease: 'power2.out',
            scrollTrigger: {
              trigger: section.querySelector('.founder-story__content'),
              start: 'top 82%'
            }
          }
        );
      }

      if (text) {
        var paragraphs = text.querySelectorAll('p');

        if (paragraphs.length) {
          gsap.fromTo(paragraphs,
            {
              y: 34,
              opacity: 0
            },
            {
              y: 0,
              opacity: 1,
              duration: 0.9,
              stagger: 0.14,
              ease: 'power2.out',
              scrollTrigger: {
                trigger: text,
                start: 'top 80%'
              }
            }
          );
        } else {
          gsap.fromTo(text,
            {
              y: 34,
              opacity: 0
            },
            {
              y: 0,
              opacity: 1,
              duration: 0.9,
              ease: 'power2.out',
              scrollTrigger: {
                trigger: text,
                start: 'top 80%'
              }
            }
          );
        }
      }

      ScrollTrigger.refresh();
    }

    document.addEventListener('DOMContentLoaded', function() {
      initFounderStory('{{ section.id }}');
    });

    document.addEventListener('shopify:section:load', function(event) {
      if (event.target && event.target.id === 'shopify-section-{{ section.id }}') {
        initFounderStory('{{ section.id }}');
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Founder story",
  "limit": 1,
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1"
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "options": [
        { "value": "container", "label": "Container" },
        { "value": "container-fluid", "label": "Container fluid" },
        { "value": "container-narrow", "label": "Container narrow" },
        { "value": "container-extra-narrow", "label": "Container extra narrow" },
        { "value": "extended", "label": "Extended" }
      ],
      "default": "container-fluid"
    },
    {
      "type": "select",
      "id": "layout_style",
      "label": "Layout style",
      "options": [
        { "value": "image-left", "label": "Image left" },
        { "value": "image-right", "label": "Image right" }
      ],
      "default": "image-left"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Leadership"
    },
    {
      "type": "text",
      "id": "name",
      "label": "Founder / CEO name",
      "default": "Meet Our Founder"
    },
    {
      "type": "text",
      "id": "designation",
      "label": "Designation",
      "default": "Founder & CEO"
    },
    {
      "type": "richtext",
      "id": "short_intro",
      "label": "Short intro",
      "default": "<p>A visionary leader shaping the company with elegance, confidence, and a clear long-term direction.</p>"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Large description",
      "default": "<p>Use this section to tell the founder story in a more premium and emotional way. Share the company vision, the journey behind the brand, and the values that guide every decision.</p><p>As the user scrolls, the content reveals softly to create a refined editorial feeling that matches a modern luxury brand presentation.</p>"
    },
    {
      "type": "text",
      "id": "signature_text",
      "label": "Signature text",
      "default": "Founder"
    },
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Founder image"
    },
    {
      "type": "text",
      "id": "image_caption",
      "label": "Image caption",
      "default": "Portrait / leadership image"
    },
    {
      "type": "range",
      "id": "image_max_width",
      "min": 280,
      "max": 900,
      "step": 10,
      "unit": "px",
      "label": "Image max width",
      "default": 520
    },
    {
      "type": "header",
      "content": "Background text"
    },
    {
      "type": "text",
      "id": "bg_text",
      "label": "Background text",
      "default": "Meet The Founder"
    },
    {
      "type": "range",
      "id": "bg_text_size",
      "min": 80,
      "max": 360,
      "step": 4,
      "unit": "px",
      "label": "Background text size",
      "default": 220
    },
    {
      "type": "range",
      "id": "bg_text_opacity",
      "min": 1,
      "max": 20,
      "step": 1,
      "unit": "%",
      "label": "Background text opacity",
      "default": 8
    },
    {
      "type": "header",
      "content": "Typography and layout"
    },
    {
      "type": "range",
      "id": "content_max_width",
      "min": 360,
      "max": 1000,
      "step": 10,
      "unit": "px",
      "label": "Content max width",
      "default": 720
    },
    {
      "type": "range",
      "id": "desktop_section_height",
      "min": 50,
      "max": 120,
      "step": 2,
      "unit": "%",
      "label": "Desktop section height",
      "default": 92
    },
    {
      "type": "range",
      "id": "name_size",
      "min": 32,
      "max": 140,
      "step": 2,
      "unit": "px",
      "label": "Name title size",
      "default": 84
    },
    {
      "type": "range",
      "id": "intro_size",
      "min": 16,
      "max": 34,
      "step": 1,
      "unit": "px",
      "label": "Intro text size",
      "default": 22
    },
    {
      "type": "range",
      "id": "body_size",
      "min": 14,
      "max": 28,
      "step": 1,
      "unit": "px",
      "label": "Body text size",
      "default": 18
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 80
    },
    {
      "type": "header",
      "content": "Dynamic option"
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom class"
    },
    {
      "type": "select",
      "id": "color_control",
      "label": "Color Control",
      "options": [
        { "value": "section-dark", "label": "Dark" },
        { "value": "section-light", "label": "Light" }
      ],
      "default": "section-light"
    }
  ],
  "presets": [
    {
      "name": "Founder story"
    }
  ]
}
{% endschema %}