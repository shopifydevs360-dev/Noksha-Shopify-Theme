{% render 'section-base-style' %}

{%- liquid
  assign section_classes = 'founder-story'
  assign section_classes = section_classes | append: ' section-' | append: section.id | append: '-padding'
  assign section_classes = section_classes | append: ' m-color-' | append: section.settings.color_scheme
  assign section_classes = section_classes | append: ' ' | append: section.settings.color_control
  assign section_classes = section_classes | append: ' ' | append: section.settings.custom_class

  assign container_class = section.settings.container_width | default: 'container-fluid'

  assign media_ratio_class = section.settings.image_ratio
  if section.settings.adapt_image_height
    assign media_ratio_class = media_ratio_class | append: ' adapt-image-height'
  endif

  assign layout_class = 'founder-story--image-' | append: section.settings.layout_style
-%}

<section class="{{ section_classes }}" id="FounderStory-{{ section.id }}" {{ section.shopify_attributes }}>
  <div class="{{ container_class }}">
    <div class="sidebar-space">
      <div class="founder-story__wrap {{ layout_class }}">

        {% if section.settings.bg_title != blank %}
          <div class="founder-story__bg-title special-font-4 founder-story__anim-bg">
            {{ section.settings.bg_title }}
          </div>
        {% endif %}

        <div class="founder-story__grid">
          <div class="founder-story__media founder-story__anim-media">
            <div class="founder-story__media-inner border-radius-style-one">
              {% render 'image',
                image: section.settings.image,
                class: 'founder-story__image cropped-image-wrapper ' | append: media_ratio_class,
                img_alt: section.settings.name,
                loading: 'lazy',
                fetchpriority: 'low'
              %}
            </div>

            {% if section.settings.image_caption != blank %}
              <div class="founder-story__image-caption founder-story__anim-fade">
                {{ section.settings.image_caption }}
              </div>
            {% endif %}
          </div>

          <div class="founder-story__content">
            {% if section.settings.eyebrow != blank %}
              <div class="founder-story__eyebrow founder-story__anim-fade">
                {{ section.settings.eyebrow }}
              </div>
            {% endif %}

            {% if section.settings.name != blank %}
              <h2 class="founder-story__name founder-story__anim-title">
                {{ section.settings.name }}
              </h2>
            {% endif %}

            {% if section.settings.designation != blank %}
              <div class="founder-story__designation founder-story__anim-fade">
                {{ section.settings.designation }}
              </div>
            {% endif %}

            {% if section.settings.short_intro != blank %}
              <div class="founder-story__intro founder-story__anim-fade rte">
                {{ section.settings.short_intro }}
              </div>
            {% endif %}

            {% if section.settings.description != blank %}
              <div class="founder-story__description founder-story__anim-text rte">
                {{ section.settings.description }}
              </div>
            {% endif %}

            {% if section.settings.signature_text != blank %}
              <div class="founder-story__signature founder-story__anim-fade special-font-3">
                {{ section.settings.signature_text }}
              </div>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .founder-story {
    position: relative;
    overflow: hidden;
    background: rgb(var(--color-background));
  }

  .founder-story__wrap {
    position: relative;
    min-height: 100%;
  }

  .founder-story__grid {
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: center;
    z-index: 2;
  }

  .founder-story__media {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: min(100%, {{ section.settings.image_max_width }}px);
    margin: 0 auto;
  }

  .founder-story__media-inner {
    overflow: hidden;
    background: rgba(var(--color-background-secondary), 1);
  }

  .founder-story__image {
    display: block;
    width: 100%;
  }

  .founder-story__image img,
  .founder-story__image svg {
    display: block;
    width: 100%;
  }

  .founder-story__content {
    position: relative;
    z-index: 3;
    width: 100%;
    max-width: {{ section.settings.content_max_width }}px;
    margin: 0 auto;
  }

  .founder-story__eyebrow {
    margin-bottom: 1rem;
    font-size: 0.82rem;
    line-height: 1.2;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(var(--color-subtext), 0.88);
  }

  .founder-story__name {
    margin: 0;
    color: rgb(var(--color-heading));
    line-height: 0.96;
    font-size: clamp(2.4rem, 7vw, {{ section.settings.name_size }}px);
    max-width: 12ch;
  }

  .founder-story__designation {
    margin-top: 0.9rem;
    margin-bottom: 1.2rem;
    color: rgba(var(--color-subtext), 0.9);
    font-size: 0.95rem;
    line-height: 1.5;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .founder-story__intro {
    margin-bottom: 1.4rem;
    color: rgb(var(--color-heading));
    font-size: clamp(1rem, 1.9vw, {{ section.settings.intro_size }}px);
    line-height: 1.65;
    max-width: 26ch;
  }

  .founder-story__description {
    color: rgb(var(--color-text));
    font-size: clamp(1rem, 1.35vw, {{ section.settings.body_size }}px);
    line-height: 1.9;
    max-width: 100%;
  }

  .founder-story__description p + p {
    margin-top: 1rem;
  }

  .founder-story__signature {
    margin-top: 1.8rem;
    color: rgb(var(--color-heading));
    font-size: clamp(1.2rem, 2vw, 2rem);
    opacity: 0.92;
  }

  .founder-story__image-caption {
    margin-top: 0.8rem;
    text-align: center;
    color: rgba(var(--color-subtext), 0.8);
    font-size: 0.84rem;
    line-height: 1.4;
  }

  .founder-story__bg-title {
    position: absolute;
    top: clamp(0rem, 2vw, 1rem);
    left: 0;
    z-index: 1;
    pointer-events: none;
    max-width: min(72vw, 900px);
    color: rgba(var(--color-additional-1), {{ section.settings.bg_title_opacity | divided_by: 100.0 }});
    font-family: var(--font-heading-family, sans-serif);
    font-size: clamp(4rem, 14vw, {{ section.settings.bg_title_size }}px);
    line-height: 0.85;
    font-weight: 300;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  @media (min-width: 992px) {
    .founder-story__grid {
      min-height: {{ section.settings.section_min_height }}vh;
      gap: clamp(2rem, 4vw, 6rem);
      grid-template-columns: minmax(320px, 0.88fr) minmax(420px, 1fr);
    }

    .founder-story--image-right .founder-story__media {
      order: 2;
    }

    .founder-story--image-right .founder-story__content {
      order: 1;
    }

    .founder-story--image-left .founder-story__media {
      order: 1;
    }

    .founder-story--image-left .founder-story__content {
      order: 2;
    }

    .founder-story__content {
      margin: 0;
    }

    .founder-story__image-caption {
      text-align: left;
    }

    .founder-story__wrap {
      padding-top: 0.5rem;
      padding-bottom: 0.5rem;
    }
  }

  @media (max-width: 991px) {
    .founder-story__wrap {
      padding-top: 0;
      padding-bottom: 0;
    }

    .founder-story__media {
      max-width: min(100%, 560px);
    }

    .founder-story__bg-title {
      top: 0;
      left: 0;
      max-width: 100%;
      font-size: clamp(3.2rem, 18vw, 8rem);
      opacity: 0.55;
      white-space: normal;
      line-height: 0.9;
    }

    .founder-story__name {
      max-width: 100%;
    }

    .founder-story__intro {
      max-width: 100%;
    }
  }
</style>

<script>
  (function() {
    function initFounderStory(sectionId) {
      var section = document.getElementById('FounderStory-' + sectionId);
      if (!section) return;

      if (section.dataset.founderStoryInit === 'true') return;
      section.dataset.founderStoryInit = 'true';

      if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;

      gsap.registerPlugin(ScrollTrigger);

      var media = section.querySelector('.founder-story__anim-media');
      var title = section.querySelector('.founder-story__anim-title');
      var fades = section.querySelectorAll('.founder-story__anim-fade');
      var text = section.querySelector('.founder-story__anim-text');
      var bgTitle = section.querySelector('.founder-story__anim-bg');
      var image = section.querySelector('.founder-story__image img');

      if (bgTitle) {
        gsap.fromTo(
          bgTitle,
          {
            y: -24,
            opacity: 0
          },
          {
            y: 0,
            opacity: 1,
            duration: 1.1,
            ease: 'power3.out',
            scrollTrigger: {
              trigger: section,
              start: 'top 82%'
            }
          }
        );

        gsap.to(bgTitle, {
          yPercent: -8,
          ease: 'none',
          scrollTrigger: {
            trigger: section,
            start: 'top bottom',
            end: 'bottom top',
            scrub: 1.2
          }
        });
      }

      if (media) {
        gsap.fromTo(
          media,
          {
            y: 55,
            opacity: 0,
            scale: 0.97
          },
          {
            y: 0,
            opacity: 1,
            scale: 1,
            duration: 1.1,
            ease: 'power3.out',
            scrollTrigger: {
              trigger: media,
              start: 'top 84%'
            }
          }
        );
      }

      if (image) {
        gsap.to(image, {
          yPercent: -6,
          ease: 'none',
          scrollTrigger: {
            trigger: section,
            start: 'top bottom',
            end: 'bottom top',
            scrub: 1.4
          }
        });
      }

      if (title) {
        gsap.fromTo(
          title,
          {
            y: 40,
            opacity: 0
          },
          {
            y: 0,
            opacity: 1,
            duration: 0.95,
            ease: 'power3.out',
            scrollTrigger: {
              trigger: title,
              start: 'top 86%'
            }
          }
        );
      }

      if (fades.length) {
        gsap.fromTo(
          fades,
          {
            y: 22,
            opacity: 0
          },
          {
            y: 0,
            opacity: 1,
            duration: 0.8,
            stagger: 0.12,
            ease: 'power2.out',
            scrollTrigger: {
              trigger: section.querySelector('.founder-story__content'),
              start: 'top 82%'
            }
          }
        );
      }

      if (text) {
        var paragraphs = text.querySelectorAll('p');

        if (paragraphs.length) {
          gsap.fromTo(
            paragraphs,
            {
              y: 28,
              opacity: 0
            },
            {
              y: 0,
              opacity: 1,
              duration: 0.85,
              stagger: 0.12,
              ease: 'power2.out',
              scrollTrigger: {
                trigger: text,
                start: 'top 80%'
              }
            }
          );
        } else {
          gsap.fromTo(
            text,
            {
              y: 28,
              opacity: 0
            },
            {
              y: 0,
              opacity: 1,
              duration: 0.85,
              ease: 'power2.out',
              scrollTrigger: {
                trigger: text,
                start: 'top 80%'
              }
            }
          );
        }
      }

      ScrollTrigger.refresh();
    }

    document.addEventListener('DOMContentLoaded', function() {
      initFounderStory('{{ section.id }}');
    });

    document.addEventListener('shopify:section:load', function(event) {
      if (event.target && event.target.id === 'shopify-section-{{ section.id }}') {
        var currentSection = document.getElementById('FounderStory-{{ section.id }}');
        if (currentSection) {
          currentSection.dataset.founderStoryInit = '';
        }
        initFounderStory('{{ section.id }}');
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Founder story",
  "limit": 1,
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1"
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "options": [
        { "value": "container", "label": "Container" },
        { "value": "container-fluid", "label": "Container fluid" },
        { "value": "container-narrow", "label": "Container narrow" },
        { "value": "container-extra-narrow", "label": "Container extra narrow" },
        { "value": "extended", "label": "Extended" }
      ],
      "default": "container-fluid"
    },
    {
      "type": "select",
      "id": "color_control",
      "label": "Color Control",
      "options": [
        { "value": "section-dark", "label": "Dark" },
        { "value": "section-light", "label": "Light" }
      ],
      "default": "section-light"
    },
    {
      "type": "select",
      "id": "layout_style",
      "label": "Layout style",
      "options": [
        { "value": "left", "label": "Image left" },
        { "value": "right", "label": "Image right" }
      ],
      "default": "left"
    },

    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Leadership"
    },
    {
      "type": "text",
      "id": "name",
      "label": "Founder / CEO name",
      "default": "Meet Our Founder"
    },
    {
      "type": "text",
      "id": "designation",
      "label": "Designation",
      "default": "Founder & CEO"
    },
    {
      "type": "richtext",
      "id": "short_intro",
      "label": "Short intro",
      "default": "<p>A visionary leader shaping the company with elegance, confidence, and a clear long-term direction.</p>"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Large description",
      "default": "<p>Use this section to tell the founder story in a more premium and emotional way. Share the company vision, the journey behind the brand, and the values that guide every decision.</p><p>As the user scrolls, the content reveals softly to create a refined editorial feeling that matches a modern luxury brand presentation.</p>"
    },
    {
      "type": "text",
      "id": "signature_text",
      "label": "Signature text",
      "default": "Founder"
    },

    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Founder image"
    },
    {
      "type": "text",
      "id": "image_caption",
      "label": "Image caption",
      "default": "Portrait / leadership image"
    },
    {
      "type": "checkbox",
      "id": "adapt_image_height",
      "label": "Adapt to actual image height",
      "default": true
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        { "value": "cropped-image--square", "label": "Square" },
        { "value": "cropped-image--portrait", "label": "Portrait" },
        { "value": "cropped-image--portrait-tall", "label": "Portrait tall" },
        { "value": "cropped-image--landscape", "label": "Landscape" },
        { "value": "cropped-image--wide", "label": "Wide" }
      ],
      "default": "cropped-image--portrait"
    },
    {
      "type": "range",
      "id": "image_max_width",
      "min": 280,
      "max": 900,
      "step": 10,
      "unit": "px",
      "label": "Image max width",
      "default": 520
    },

    {
      "type": "header",
      "content": "Background title"
    },
    {
      "type": "text",
      "id": "bg_title",
      "label": "Background title",
      "default": "Founder"
    },
    {
      "type": "range",
      "id": "bg_title_size",
      "min": 80,
      "max": 360,
      "step": 4,
      "unit": "px",
      "label": "Background title size",
      "default": 220
    },
    {
      "type": "range",
      "id": "bg_title_opacity",
      "min": 1,
      "max": 25,
      "step": 1,
      "unit": "%",
      "label": "Background title opacity",
      "default": 10
    },

    {
      "type": "header",
      "content": "Layout control"
    },
    {
      "type": "range",
      "id": "content_max_width",
      "min": 360,
      "max": 1000,
      "step": 10,
      "unit": "px",
      "label": "Content max width",
      "default": 720
    },
    {
      "type": "range",
      "id": "section_min_height",
      "min": 50,
      "max": 120,
      "step": 2,
      "unit": "%",
      "label": "Desktop section height",
      "default": 92
    },

    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "name_size",
      "min": 32,
      "max": 140,
      "step": 2,
      "unit": "px",
      "label": "Name title size",
      "default": 80
    },
    {
      "type": "range",
      "id": "intro_size",
      "min": 16,
      "max": 34,
      "step": 1,
      "unit": "px",
      "label": "Intro text size",
      "default": 22
    },
    {
      "type": "range",
      "id": "body_size",
      "min": 14,
      "max": 28,
      "step": 1,
      "unit": "px",
      "label": "Body text size",
      "default": 18
    },

    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 80
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom class"
    }
  ],
  "presets": [
    {
      "name": "Founder story"
    }
  ]
}
{% endschema %}