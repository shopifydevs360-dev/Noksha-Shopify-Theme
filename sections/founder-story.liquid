{%- liquid
  assign fs_outer_classes = 'founder-story'
  assign fs_outer_classes = fs_outer_classes | append: ' section-' | append: section.id | append: '-padding'
  assign fs_outer_classes = fs_outer_classes | append: ' m-color-' | append: section.settings.color_scheme
  assign fs_outer_classes = fs_outer_classes | append: ' ' | append: section.settings.custom_class
  assign fs_outer_classes = fs_outer_classes | append: ' ' | append: section.settings.color_control

  assign fs_inner_classes = ''
  assign fs_inner_classes = fs_inner_classes | append: ' ' | append: section.settings.container_width
-%}

<section class="{{ fs_outer_classes }}" {{ section.shopify_attributes }}>
  <div class="{{ fs_inner_classes }}">
    <div class="sidebar-space">
      <div class="founder-story__wrapper founder-story__layout-{{ section.settings.layout_style }}">

        {% if section.settings.bg_title_top != blank %}
          <div class="founder-story__bg-title founder-story__bg-title--top special-font-4">
            {{ section.settings.bg_title_top }}
          </div>
        {% endif %}

        {% if section.settings.bg_title_bottom != blank %}
          <div class="founder-story__bg-title founder-story__bg-title--bottom special-font-4">
            {{ section.settings.bg_title_bottom }}
          </div>
        {% endif %}

        <div class="founder-story__grid">
          <div class="founder-story__media founder-story__anim-media">
            <div class="founder-story__media-inner border-radius-style-one">
              {% render 'image',
                image: section.settings.image,
                class: 'founder-story__image adapt-image-height',
                img_alt: section.settings.name,
                loading: 'lazy',
                fetchpriority: 'low'
              %}
            </div>

            {% if section.settings.image_caption != blank %}
              <div class="founder-story__image-caption founder-story__anim-fade">
                {{ section.settings.image_caption }}
              </div>
            {% endif %}
          </div>

          <div class="founder-story__content">
            {% if section.settings.eyebrow != blank %}
              <div class="founder-story__eyebrow founder-story__anim-fade">
                {{ section.settings.eyebrow }}
              </div>
            {% endif %}

            {% if section.settings.name != blank %}
              <h2 class="founder-story__title founder-story__anim-title">
                {{ section.settings.name }}
              </h2>
            {% endif %}

            {% if section.settings.designation != blank %}
              <div class="founder-story__designation founder-story__anim-fade">
                {{ section.settings.designation }}
              </div>
            {% endif %}

            {% if section.settings.short_intro != blank %}
              <div class="founder-story__intro founder-story__anim-fade rte">
                {{ section.settings.short_intro }}
              </div>
            {% endif %}

            {% if section.settings.description != blank %}
              <div class="founder-story__description founder-story__anim-text rte">
                {{ section.settings.description }}
              </div>
            {% endif %}

            {% if section.settings.signature_text != blank %}
              <div class="founder-story__signature founder-story__anim-fade special-font-3">
                {{ section.settings.signature_text }}
              </div>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .founder-story {
    position: relative;
    overflow: hidden;
    background: rgb(var(--color-background));
  }

  .founder-story__wrapper {
    position: relative;
  }

  .founder-story__grid {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
  }

  .founder-story__media {
    position: relative;
    z-index: 2;
    max-width: min(100%, {{ section.settings.image_max_width }}px);
    margin: 0 auto;
  }

  .founder-story__media-inner {
    overflow: hidden;
    background: rgb(var(--color-background-secondary));
  }

  .founder-story__image {
    display: block;
    width: 100%;
  }

  .founder-story__image img,
  .founder-story__image svg {
    display: block;
    width: 100%;
    height: auto;
  }

  .founder-story__content {
    position: relative;
    z-index: 3;
    max-width: {{ section.settings.content_max_width }}px;
    margin: 0 auto;
  }

  .founder-story__eyebrow {
    margin-bottom: 0.9rem;
    font-size: 0.82rem;
    line-height: 1;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(var(--color-subtext), 0.95);
  }

  .founder-story__title {
    margin: 0;
    color: rgb(var(--color-heading));
    line-height: 0.96;
    font-size: clamp(2.2rem, 6vw, {{ section.settings.title_size }}px);
  }

  .founder-story__designation {
    margin-top: 1rem;
    margin-bottom: 1.1rem;
    font-size: 0.95rem;
    line-height: 1.4;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(var(--color-subtext), 0.9);
  }

  .founder-story__intro {
    margin-bottom: 1.4rem;
    font-size: clamp(1rem, 1.6vw, {{ section.settings.intro_size }}px);
    line-height: 1.65;
    color: rgb(var(--color-heading));
  }

  .founder-story__description {
    font-size: clamp(0.98rem, 1.2vw, {{ section.settings.body_size }}px);
    line-height: 1.9;
    color: rgb(var(--color-text));
  }

  .founder-story__description p + p {
    margin-top: 1rem;
  }

  .founder-story__signature {
    margin-top: 1.7rem;
    font-size: clamp(1.25rem, 2vw, 2rem);
    line-height: 1.2;
    color: rgb(var(--color-heading));
    opacity: 0.92;
  }

  .founder-story__image-caption {
    margin-top: 0.8rem;
    font-size: 0.84rem;
    line-height: 1.5;
    color: rgba(var(--color-subtext), 0.8);
    text-align: center;
  }

  .founder-story__bg-title {
    position: absolute;
    z-index: 1;
    pointer-events: none;
    white-space: nowrap;
    line-height: 0.9;
    font-family: var(--font-heading-family, sans-serif);
    font-weight: 300;
    text-transform: uppercase;
    letter-spacing: 0;
    color: rgba(var(--color-additional-1), {{ section.settings.bg_title_opacity | divided_by: 100.0 }});
    font-size: clamp(4rem, 11vw, {{ section.settings.bg_title_size }}px);
  }

  .founder-story__bg-title--top {
    top: 0;
    left: 0;
  }

  .founder-story__bg-title--bottom {
    right: 0;
    bottom: 0;
  }

  @media (min-width: 992px) {
    .founder-story__grid {
      grid-template-columns: minmax(320px, 0.85fr) minmax(420px, 1fr);
      gap: clamp(2rem, 5vw, 7rem);
      min-height: {{ section.settings.section_height }}vh;
    }

    .founder-story__layout-image-right .founder-story__media {
      order: 2;
      margin-left: auto;
      margin-right: 0;
    }

    .founder-story__layout-image-right .founder-story__content {
      order: 1;
      margin-left: 0;
      margin-right: auto;
    }

    .founder-story__layout-image-left .founder-story__media {
      order: 1;
      margin-left: 0;
      margin-right: auto;
    }

    .founder-story__layout-image-left .founder-story__content {
      order: 2;
      margin-left: auto;
      margin-right: 0;
    }

    .founder-story__image-caption {
      text-align: left;
    }

    .founder-story__bg-title--top {
      top: -0.5rem;
      left: 0;
    }

    .founder-story__bg-title--bottom {
      right: 0;
      bottom: -0.3rem;
    }
  }

  @media (max-width: 991px) {
    .founder-story__wrapper {
      padding-top: 1rem;
      padding-bottom: 1rem;
    }

    .founder-story__bg-title {
      font-size: clamp(3rem, 16vw, 6rem);
      opacity: 0.6;
    }

    .founder-story__bg-title--top {
      top: -0.2rem;
      left: 0;
    }

    .founder-story__bg-title--bottom {
      right: 0;
      bottom: 0;
    }

    .founder-story__media {
      max-width: min(100%, 520px);
    }
  }
</style>

<script>
  (function () {
    function initFounderStory() {
      var section = document.querySelector('.founder-story');
      if (!section) return;
      if (section.dataset.founderInitialized === 'true') return;
      section.dataset.founderInitialized = 'true';

      if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;

      gsap.registerPlugin(ScrollTrigger);

      var media = section.querySelector('.founder-story__anim-media');
      var title = section.querySelector('.founder-story__anim-title');
      var fades = section.querySelectorAll('.founder-story__anim-fade');
      var textWrap = section.querySelector('.founder-story__anim-text');
      var bgTitles = section.querySelectorAll('.founder-story__bg-title');
      var image = section.querySelector('.founder-story__image img');

      if (bgTitles.length) {
        bgTitles.forEach(function (item, index) {
          gsap.fromTo(item,
            {
              y: index === 0 ? -20 : 20,
              opacity: 0
            },
            {
              y: 0,
              opacity: 1,
              duration: 1.2,
              ease: 'power3.out',
              scrollTrigger: {
                trigger: section,
                start: 'top 85%'
              }
            }
          );

          gsap.to(item, {
            yPercent: index === 0 ? -8 : 8,
            ease: 'none',
            scrollTrigger: {
              trigger: section,
              start: 'top bottom',
              end: 'bottom top',
              scrub: 1.2
            }
          });
        });
      }

      if (media) {
        gsap.fromTo(media,
          {
            y: 60,
            opacity: 0,
            scale: 0.96
          },
          {
            y: 0,
            opacity: 1,
            scale: 1,
            duration: 1.1,
            ease: 'power3.out',
            scrollTrigger: {
              trigger: media,
              start: 'top 82%'
            }
          }
        );
      }

      if (image) {
        gsap.to(image, {
          yPercent: -7,
          ease: 'none',
          scrollTrigger: {
            trigger: section,
            start: 'top bottom',
            end: 'bottom top',
            scrub: 1.4
          }
        });
      }

      if (title) {
        gsap.fromTo(title,
          {
            y: 40,
            opacity: 0
          },
          {
            y: 0,
            opacity: 1,
            duration: 1,
            ease: 'power3.out',
            scrollTrigger: {
              trigger: title,
              start: 'top 85%'
            }
          }
        );
      }

      if (fades.length) {
        gsap.fromTo(fades,
          {
            y: 24,
            opacity: 0
          },
          {
            y: 0,
            opacity: 1,
            duration: 0.8,
            stagger: 0.12,
            ease: 'power2.out',
            scrollTrigger: {
              trigger: section.querySelector('.founder-story__content'),
              start: 'top 82%'
            }
          }
        );
      }

      if (textWrap) {
        var paragraphs = textWrap.querySelectorAll('p');

        if (paragraphs.length) {
          gsap.fromTo(paragraphs,
            {
              y: 28,
              opacity: 0
            },
            {
              y: 0,
              opacity: 1,
              duration: 0.85,
              stagger: 0.14,
              ease: 'power2.out',
              scrollTrigger: {
                trigger: textWrap,
                start: 'top 78%'
              }
            }
          );
        } else {
          gsap.fromTo(textWrap,
            {
              y: 28,
              opacity: 0
            },
            {
              y: 0,
              opacity: 1,
              duration: 0.85,
              ease: 'power2.out',
              scrollTrigger: {
                trigger: textWrap,
                start: 'top 78%'
              }
            }
          );
        }
      }

      ScrollTrigger.refresh();
    }

    document.addEventListener('DOMContentLoaded', initFounderStory);
    document.addEventListener('shopify:section:load', initFounderStory);
  })();
</script>

{% schema %}
{
  "name": "Founder story",
  "limit": 1,
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1"
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "options": [
        { "value": "container", "label": "Container" },
        { "value": "container-fluid", "label": "Container fluid" },
        { "value": "full-width", "label": "Full width" },
        { "value": "extended", "label": "Extended" }
      ],
      "default": "container-fluid"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Leadership"
    },
    {
      "type": "text",
      "id": "name",
      "label": "Founder / CEO name",
      "default": "Meet Our Founder"
    },
    {
      "type": "text",
      "id": "designation",
      "label": "Designation",
      "default": "Founder & CEO"
    },
    {
      "type": "richtext",
      "id": "short_intro",
      "label": "Short intro",
      "default": "<p>A visionary leader shaping the company with elegance, confidence, and a clear long-term direction.</p>"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Large description",
      "default": "<p>Use this section to tell the founder story in a more premium and emotional way. Share the company vision, the journey behind the brand, and the values that guide every decision.</p><p>As the user scrolls, the content reveals softly to create a refined editorial feeling that matches a modern luxury brand presentation.</p>"
    },
    {
      "type": "text",
      "id": "signature_text",
      "label": "Signature text",
      "default": "Founder"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Founder image"
    },
    {
      "type": "text",
      "id": "image_caption",
      "label": "Image caption"
    },
    {
      "type": "select",
      "id": "layout_style",
      "label": "Layout style",
      "options": [
        { "value": "image-left", "label": "Image left" },
        { "value": "image-right", "label": "Image right" }
      ],
      "default": "image-left"
    },
    {
      "type": "header",
      "content": "Background title"
    },
    {
      "type": "text",
      "id": "bg_title_top",
      "label": "Top background title",
      "default": "MEET CEO"
    },
    {
      "type": "text",
      "id": "bg_title_bottom",
      "label": "Bottom background title",
      "default": "FOUNDER"
    },
    {
      "type": "range",
      "id": "bg_title_size",
      "min": 60,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Background title size",
      "default": 160
    },
    {
      "type": "range",
      "id": "bg_title_opacity",
      "min": 1,
      "max": 20,
      "step": 1,
      "unit": "%",
      "label": "Background title opacity",
      "default": 7
    },
    {
      "type": "header",
      "content": "Layout control"
    },
    {
      "type": "range",
      "id": "image_max_width",
      "min": 280,
      "max": 900,
      "step": 10,
      "unit": "px",
      "label": "Image max width",
      "default": 500
    },
    {
      "type": "range",
      "id": "content_max_width",
      "min": 360,
      "max": 1000,
      "step": 10,
      "unit": "px",
      "label": "Content max width",
      "default": 720
    },
    {
      "type": "range",
      "id": "section_height",
      "min": 50,
      "max": 120,
      "step": 2,
      "unit": "%",
      "label": "Desktop section height",
      "default": 90
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 28,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Title size",
      "default": 64
    },
    {
      "type": "range",
      "id": "intro_size",
      "min": 16,
      "max": 34,
      "step": 1,
      "unit": "px",
      "label": "Intro size",
      "default": 22
    },
    {
      "type": "range",
      "id": "body_size",
      "min": 14,
      "max": 28,
      "step": 1,
      "unit": "px",
      "label": "Body text size",
      "default": 18
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 80
    },
    {
      "type": "header",
      "content": "Dynamic Option"
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom class"
    },
    {
      "type": "select",
      "id": "color_control",
      "label": "Color Control",
      "options": [
        { "value": "section-dark", "label": "Dark" },
        { "value": "section-light", "label": "Light" }
      ],
      "default": "section-light"
    }
  ],
  "presets": [
    {
      "name": "Founder story"
    }
  ]
}
{% endschema %}