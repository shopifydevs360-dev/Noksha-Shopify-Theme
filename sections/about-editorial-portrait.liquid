{% render 'section-base-style' %}

{% liquid
  assign ss = section.settings

  assign first_class = 'about-editorial-portrait m-color-' | append: ss.color_scheme
  assign first_class = first_class | append: ' ' | append: ss.color_control
  assign first_class = first_class | append: ' ' | append: ss.custom_class
  assign first_class = first_class | append: ' ' | append: 'section-' | append: section.id | append: '-padding'

  assign container_width = ss.container_width

  assign portrait_classes = 'cropped-image-wrapper about-editorial-portrait__image '
  if ss.aspect_ratio == 'adapt-to-image'
    assign portrait_classes = portrait_classes | append: 'adapt-image-height'
  else
    assign portrait_classes = portrait_classes | append: ss.aspect_ratio
  endif

  if ss.hover_effect_action != 'no-effect'
    assign portrait_classes = portrait_classes | append: ' ' | append: ss.hover_effect_action
  endif

  assign panel_count = section.blocks.size | plus: 1
%}

<div class="{{ first_class }}" id="about-editorial-portrait-{{ section.id }}">
  <div class="{{ container_width }}">
    <div class="inner-section {% if ss.enable_sidebar_space %}sidebar-space{% endif %}">
      <div class="about-editorial-portrait__scene" data-editorial-scene data-panels="{{ panel_count }}">
        {% if ss.bg_word_top != blank %}
          <div class="about-editorial-portrait__word about-editorial-portrait__word--top" data-word-top>
            {{ ss.bg_word_top }}
          </div>
        {% endif %}

        {% if ss.bg_word_bottom != blank %}
          <div class="about-editorial-portrait__word about-editorial-portrait__word--bottom" data-word-bottom>
            {{ ss.bg_word_bottom }}
          </div>
        {% endif %}

        <div class="about-editorial-portrait__sticky" data-editorial-sticky>
          <div class="about-editorial-portrait__grid">
            <div class="about-editorial-portrait__content-col">
              <div class="about-editorial-portrait__panels" data-editorial-panels>
                <div class="about-editorial-portrait__panel about-editorial-portrait__panel--intro" data-editorial-panel>
                  {% if ss.subheading != blank %}
                    <div class="about-editorial-portrait__eyebrow">
                      {{ ss.subheading }}
                    </div>
                  {% endif %}

                  {% if ss.heading != blank %}
                    <h2 class="about-editorial-portrait__heading {{ ss.font_size }}">
                      {{ ss.heading }}
                    </h2>
                  {% endif %}

                  {% if ss.short_text != blank %}
                    <div class="about-editorial-portrait__text rte">
                      {{ ss.short_text }}
                    </div>
                  {% endif %}

                  {% if ss.button_label != blank and ss.button_link != blank %}
                    <div class="about-editorial-portrait__button-row">
                      <a href="{{ ss.button_link }}" class="btn {{ ss.button_style }}">
                        {{ ss.button_label }}
                      </a>
                    </div>
                  {% endif %}
                </div>

                {% for block in section.blocks %}
                  {% case block.type %}
                    {% when 'text_block' %}
                      <div class="about-editorial-portrait__panel about-editorial-portrait__panel--story" data-editorial-panel {{ block.shopify_attributes }}>
                        {% if block.settings.title != blank %}
                          <h3 class="about-editorial-portrait__block-title">{{ block.settings.title }}</h3>
                        {% endif %}
                        {% if block.settings.text != blank %}
                          <div class="about-editorial-portrait__block-text rte">
                            {{ block.settings.text }}
                          </div>
                        {% endif %}
                      </div>

                    {% when 'highlight' %}
                      <div class="about-editorial-portrait__panel about-editorial-portrait__panel--highlight" data-editorial-panel {{ block.shopify_attributes }}>
                        {% if block.settings.number != blank %}
                          <div class="about-editorial-portrait__highlight-number">{{ block.settings.number }}</div>
                        {% endif %}
                        {% if block.settings.label != blank %}
                          <div class="about-editorial-portrait__highlight-label">{{ block.settings.label }}</div>
                        {% endif %}
                      </div>
                  {% endcase %}
                {% endfor %}
              </div>

              <div class="about-editorial-portrait__progress">
                <span class="about-editorial-portrait__progress-line"></span>
                <span class="about-editorial-portrait__progress-fill" data-editorial-progress></span>
              </div>
            </div>

            <div class="about-editorial-portrait__media-col">
              <div class="about-editorial-portrait__media-wrap" data-portrait-wrap>
                <div class="about-editorial-portrait__media" data-portrait-media>
                  {% render 'image',
                    class: portrait_classes,
                    image: ss.image,
                    mobile_image: ss.image_mobile,
                    width: 1800,
                    img_alt: ss.heading,
                    loading: 'lazy'
                  %}
                </div>

                <div class="about-editorial-portrait__shape" data-portrait-shape></div>
              </div>
            </div>
          </div>
        </div>

        <div class="about-editorial-portrait__mobile-stack">
          <div class="about-editorial-portrait__mobile-media">
            {% render 'image',
              class: portrait_classes,
              image: ss.image,
              mobile_image: ss.image_mobile,
              width: 1400,
              img_alt: ss.heading,
              loading: 'lazy'
            %}
          </div>

          <div class="about-editorial-portrait__mobile-content">
            <div class="about-editorial-portrait__panel about-editorial-portrait__panel--intro is-mobile-visible">
              {% if ss.subheading != blank %}
                <div class="about-editorial-portrait__eyebrow">
                  {{ ss.subheading }}
                </div>
              {% endif %}

              {% if ss.heading != blank %}
                <h2 class="about-editorial-portrait__heading {{ ss.font_size }}">
                  {{ ss.heading }}
                </h2>
              {% endif %}

              {% if ss.short_text != blank %}
                <div class="about-editorial-portrait__text rte">
                  {{ ss.short_text }}
                </div>
              {% endif %}
            </div>

            {% for block in section.blocks %}
              {% case block.type %}
                {% when 'text_block' %}
                  <div class="about-editorial-portrait__panel about-editorial-portrait__panel--story is-mobile-visible" {{ block.shopify_attributes }}>
                    {% if block.settings.title != blank %}
                      <h3 class="about-editorial-portrait__block-title">{{ block.settings.title }}</h3>
                    {% endif %}
                    {% if block.settings.text != blank %}
                      <div class="about-editorial-portrait__block-text rte">
                        {{ block.settings.text }}
                      </div>
                    {% endif %}
                  </div>

                {% when 'highlight' %}
                  <div class="about-editorial-portrait__panel about-editorial-portrait__panel--highlight is-mobile-visible" {{ block.shopify_attributes }}>
                    {% if block.settings.number != blank %}
                      <div class="about-editorial-portrait__highlight-number">{{ block.settings.number }}</div>
                    {% endif %}
                    {% if block.settings.label != blank %}
                      <div class="about-editorial-portrait__highlight-label">{{ block.settings.label }}</div>
                    {% endif %}
                  </div>
              {% endcase %}
            {% endfor %}

            {% if ss.button_label != blank and ss.button_link != blank %}
              <div class="about-editorial-portrait__button-row is-mobile-visible">
                <a href="{{ ss.button_link }}" class="btn {{ ss.button_style }}">
                  {{ ss.button_label }}
                </a>
              </div>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
.about-editorial-portrait {
  overflow: hidden;
}

.about-editorial-portrait__scene {
  position: relative;
}

.about-editorial-portrait__word {
  position: absolute;
  font-family: var(--font-heading-family, sans-serif);
  font-weight: var(--font-heading-weight, 600);
  line-height: 0.82;
  letter-spacing: -0.05em;
  color: rgba(var(--color-heading), 0.09);
  pointer-events: none;
  user-select: none;
  z-index: 1;
  white-space: nowrap;
}

.about-editorial-portrait__word--top {
  top: 1rem;
  left: 0;
  font-size: clamp(4.5rem, 12vw, 11rem);
}

.about-editorial-portrait__word--bottom {
  right: 0;
  bottom: 2rem;
  text-align: right;
  font-size: clamp(4rem, 11vw, 10rem);
}

.about-editorial-portrait__sticky {
  position: relative;
  z-index: 2;
  min-height: 100svh;
  display: flex;
  align-items: center;
}

.about-editorial-portrait__grid {
  display: grid;
  grid-template-columns: 1fr;
  width: 100%;
  align-items: center;
}

.about-editorial-portrait__content-col {
  position: relative;
}

.about-editorial-portrait__panels {
  position: relative;
  min-height: 24rem;
}

.about-editorial-portrait__panel {
  background: rgb(var(--color-background));
  box-shadow: 0 18px 50px rgba(0, 0, 0, 0.06);
}

.about-editorial-portrait__panel--intro,
.about-editorial-portrait__panel--story,
.about-editorial-portrait__panel--highlight {
  padding: 1.25rem;
}

.about-editorial-portrait__eyebrow {
  margin-bottom: 0.6rem;
  font-size: 0.76em;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: rgba(var(--color-heading), 0.62);
}

.about-editorial-portrait__heading {
  margin: 0 0 0.75rem;
  line-height: 1.05;
}

.about-editorial-portrait__text {
  color: rgba(var(--color-text), 0.8);
}

.about-editorial-portrait__text p,
.about-editorial-portrait__block-text p {
  margin-bottom: 0.95rem;
  line-height: 1.8;
}

.about-editorial-portrait__block-text p:last-child,
.about-editorial-portrait__text p:last-child {
  margin-bottom: 0;
}

.about-editorial-portrait__block-title {
  margin: 0 0 0.8rem;
  line-height: 1.15;
}

.about-editorial-portrait__highlight-number {
  font-family: var(--font-heading-family, sans-serif);
  font-size: clamp(2.1rem, 4vw, 3.8rem);
  line-height: 1;
  margin-bottom: 0.45rem;
  color: rgb(var(--color-heading));
}

.about-editorial-portrait__highlight-label {
  color: rgba(var(--color-text), 0.78);
  line-height: 1.65;
}

.about-editorial-portrait__button-row {
  margin-top: 1.2rem;
}

.about-editorial-portrait__progress {
  display: none;
}

.about-editorial-portrait__media-col {
  position: relative;
}

.about-editorial-portrait__media-wrap {
  position: relative;
  width: min(100%, 38rem);
  margin: 0 auto;
}

.about-editorial-portrait__media {
  position: relative;
  z-index: 3;
  width: 100%;
  will-change: transform;
  transform-origin: center center;
}

.about-editorial-portrait__shape {
  position: absolute;
  width: 10rem;
  height: 10rem;
  border-radius: 50%;
  background: rgba(var(--color-additional-1), 0.10);
  right: -2rem;
  bottom: 10%;
  z-index: 1;
  will-change: transform;
}

.about-editorial-portrait__mobile-stack {
  display: none;
}

@media (min-width: 991px) {
  .about-editorial-portrait__scene {
    min-height: 220vh;
  }

  .about-editorial-portrait__sticky {
    min-height: 100svh;
  }

  .about-editorial-portrait__grid {
    grid-template-columns: minmax(22rem, 0.92fr) minmax(22rem, 1.08fr);
    gap: 2rem;
  }

  .about-editorial-portrait__content-col {
    z-index: 4;
  }

  .about-editorial-portrait__panels {
    min-height: 28rem;
    max-width: 30rem;
  }

  .about-editorial-portrait__panel {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .about-editorial-portrait__panel--intro,
  .about-editorial-portrait__panel--story,
  .about-editorial-portrait__panel--highlight {
    padding: 1.8rem 1.8rem 2rem;
  }

  .about-editorial-portrait__progress {
    display: block;
    position: relative;
    width: 100%;
    max-width: 30rem;
    height: 2px;
    margin-top: 1.4rem;
    background: rgba(var(--color-border), 0.75);
    overflow: hidden;
  }

  .about-editorial-portrait__progress-fill {
    position: absolute;
    inset: 0 auto 0 0;
    width: 0%;
    background: rgb(var(--color-heading));
  }

  .about-editorial-portrait__media-wrap {
    width: min(100%, 42rem);
    min-height: 42rem;
  }

  .about-editorial-portrait__media {
    width: min(100%, 36rem);
    margin: 0 auto;
  }

  .about-editorial-portrait__shape {
    width: 11rem;
    height: 11rem;
    right: 0;
    bottom: 12%;
  }
}

@media (max-width: 990px) {
  .about-editorial-portrait__sticky {
    display: none;
  }

  .about-editorial-portrait__word {
    display: none;
  }

  .about-editorial-portrait__mobile-stack {
    display: block;
  }

  .about-editorial-portrait__mobile-media {
    max-width: 34rem;
    margin: 0 auto 1.5rem;
  }

  .about-editorial-portrait__mobile-content {
    max-width: 34rem;
    margin: 0 auto;
    display: grid;
    gap: 1rem;
  }
}

@media (max-width: 767px) {
  .about-editorial-portrait__panel--intro,
  .about-editorial-portrait__panel--story,
  .about-editorial-portrait__panel--highlight {
    padding: 1rem;
  }

  .about-editorial-portrait__text p,
  .about-editorial-portrait__block-text p {
    line-height: 1.7;
  }
}
{% endstylesheet %}

<script>
  (function() {
    function initAboutEditorialPortrait(sectionId) {
      var section = document.getElementById('about-editorial-portrait-' + sectionId);
      if (!section || section.dataset.gsapInitialized === 'true') return;

      section.dataset.gsapInitialized = 'true';

      if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;

      gsap.registerPlugin(ScrollTrigger);

      var scene = section.querySelector('[data-editorial-scene]');
      var sticky = section.querySelector('[data-editorial-sticky]');
      var panels = section.querySelectorAll('[data-editorial-panel]');
      var portraitMedia = section.querySelector('[data-portrait-media]');
      var portraitShape = section.querySelector('[data-portrait-shape]');
      var progress = section.querySelector('[data-editorial-progress]');
      var wordTop = section.querySelector('[data-word-top]');
      var wordBottom = section.querySelector('[data-word-bottom]');
      var panelCount = parseInt(scene.getAttribute('data-panels'), 10) || panels.length || 1;

      if (!scene || !sticky || !panels.length || !portraitMedia) return;

      var mm = gsap.matchMedia();

      mm.add('(min-width: 991px)', function() {
        gsap.set(panels, {
          autoAlpha: 0,
          y: 40
        });

        gsap.set(panels[0], {
          autoAlpha: 1,
          y: 0
        });

        gsap.set(portraitMedia, {
          xPercent: 0,
          yPercent: 0,
          scale: 1
        });

        if (portraitShape) {
          gsap.set(portraitShape, {
            xPercent: 0,
            yPercent: 0
          });
        }

        var timeline = gsap.timeline({
          scrollTrigger: {
            trigger: scene,
            start: 'top top',
            end: '+=' + ((panelCount + 1) * 90) + '%',
            scrub: 1,
            pin: sticky,
            anticipatePin: 1,
            invalidateOnRefresh: true
          }
        });

        timeline.to(portraitMedia, {
          scale: 0.72,
          xPercent: 24,
          yPercent: -2,
          ease: 'none',
          duration: 1.2
        }, 0);

        if (portraitShape) {
          timeline.to(portraitShape, {
            xPercent: -18,
            yPercent: 14,
            ease: 'none',
            duration: 1.2
          }, 0);
        }

        if (wordTop) {
          timeline.to(wordTop, {
            xPercent: -12,
            ease: 'none',
            duration: 1.2
          }, 0);
        }

        if (wordBottom) {
          timeline.to(wordBottom, {
            xPercent: 14,
            ease: 'none',
            duration: 1.2
          }, 0);
        }

        panels.forEach(function(panel, index) {
          var enterAt = 0.25 + (index * 0.85);

          timeline.to(panel, {
            autoAlpha: 1,
            y: 0,
            duration: 0.28,
            ease: 'power2.out'
          }, enterAt);

          if (index < panels.length - 1) {
            timeline.to(panel, {
              autoAlpha: 0,
              y: -18,
              duration: 0.22,
              ease: 'power2.inOut'
            }, enterAt + 0.48);
          }
        });

        if (progress) {
          gsap.to(progress, {
            width: '100%',
            ease: 'none',
            scrollTrigger: {
              trigger: scene,
              start: 'top top',
              end: '+=' + ((panelCount + 1) * 90) + '%',
              scrub: 1
            }
          });
        }

        return function() {
          ScrollTrigger.getAll().forEach(function(trigger) {
            if (
              trigger.trigger === scene ||
              trigger.trigger === panels[0]
            ) {
              trigger.kill();
            }
          });
        };
      });

      mm.add('(max-width: 990px)', function() {
        gsap.set(section.querySelectorAll('.is-mobile-visible'), {
          clearProps: 'all'
        });
      });
    }

    document.addEventListener('DOMContentLoaded', function() {
      initAboutEditorialPortrait('{{ section.id }}');
    });

    document.addEventListener('shopify:section:load', function(event) {
      if (event.target && event.target.querySelector('#about-editorial-portrait-{{ section.id }}')) {
        initAboutEditorialPortrait('{{ section.id }}');
      }
    });
  })();
</script>

{% schema %}
{
  "name": "About editorial portrait",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "checkbox",
      "id": "enable_sidebar_space",
      "label": "Enable sidebar space",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme"
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "options": [
        { "value": "container", "label": "Container" },
        { "value": "container-fluid", "label": "Container fluid" },
        { "value": "container-narrow", "label": "Container narrow" },
        { "value": "container-extra-narrow", "label": "Container extra narrow" },
        { "value": "full-width", "label": "Full width" },
        { "value": "extended", "label": "Extended" }
      ],
      "default": "extended"
    },
    {
      "type": "select",
      "id": "font_size",
      "label": "Heading size",
      "options": [
        { "value": "h1", "label": "h1" },
        { "value": "h2", "label": "h2" },
        { "value": "h3", "label": "h3" },
        { "value": "h4", "label": "h4" }
      ],
      "default": "h2"
    },
    {
      "type": "header",
      "content": "Background words"
    },
    {
      "type": "textarea",
      "id": "bg_word_top",
      "label": "Top word",
      "default": "MEET"
    },
    {
      "type": "textarea",
      "id": "bg_word_bottom",
      "label": "Bottom word",
      "default": "FOUNDER"
    },
    {
      "type": "header",
      "content": "Intro panel"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "About the founder"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "A refined vision behind the brand."
    },
    {
      "type": "richtext",
      "id": "short_text",
      "label": "Short text",
      "default": "<p>Introduce the founder with a strong editorial image and a concise, elegant overview.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Read our story"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button style",
      "options": [
        { "value": "btn--primary", "label": "Primary" },
        { "value": "btn--secondary", "label": "Secondary" },
        { "value": "btn--underline", "label": "Underline" }
      ],
      "default": "btn--primary"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Portrait image"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Portrait image mobile"
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Image aspect ratio",
      "options": [
        { "value": "adapt-to-image", "label": "Adapt to image" },
        { "value": "cropped-image--square", "label": "Square" },
        { "value": "cropped-image--portrait", "label": "Portrait" },
        { "value": "cropped-image--portrait-tall", "label": "Portrait tall" },
        { "value": "cropped-image--landscape", "label": "Landscape" },
        { "value": "cropped-image--wide", "label": "Wide" }
      ],
      "default": "cropped-image--portrait-tall"
    },
    {
      "type": "select",
      "id": "hover_effect_action",
      "label": "Image hover effect",
      "options": [
        { "value": "no-effect", "label": "No effect" },
        { "value": "is-hover-zoom-in", "label": "Zoom in" },
        { "value": "is-hover-zoom-out", "label": "Zoom out" },
        { "value": "is-hover-zoom-up", "label": "Zoom up" },
        { "value": "is-hover-fade", "label": "Fade" },
        { "value": "is-hover-cinematic", "label": "Cinematic" },
        { "value": "is-hover-drift", "label": "Drift" },
        { "value": "is-hover-overlay", "label": "Overlay" }
      ],
      "default": "no-effect"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Top padding",
      "default": 70
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Bottom padding",
      "default": 70
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom class"
    },
    {
      "type": "select",
      "id": "color_control",
      "label": "Color Control",
      "options": [
        { "value": "section-dark", "label": "Dark" },
        { "value": "section-light", "label": "Light" }
      ],
      "default": "section-light"
    }
  ],
  "blocks": [
    {
      "type": "text_block",
      "name": "Story block",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Block title",
          "default": "Her journey began with a clear vision"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Block text",
          "default": "<p>Add a readable part of the founder story here.</p>"
        }
      ]
    },
    {
      "type": "highlight",
      "name": "Highlight block",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number / short highlight",
          "default": "2017"
        },
        {
          "type": "text",
