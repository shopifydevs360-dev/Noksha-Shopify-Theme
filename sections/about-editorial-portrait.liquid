{% render 'section-base-style' %}

{% liquid
  assign ss = section.settings

  assign first_class = 'about-editorial-portrait m-color-' | append: ss.color_scheme
  assign first_class = first_class | append: ' ' | append: ss.color_control
  assign first_class = first_class | append: ' ' | append: ss.custom_class
  assign first_class = first_class | append: ' ' | append: 'section-' | append: section.id | append: '-padding'

  assign container_width = ss.container_width

  assign portrait_classes = 'cropped-image-wrapper about-editorial-portrait__image '
  if ss.aspect_ratio == 'adapt-to-image'
    assign portrait_classes = portrait_classes | append: 'adapt-image-height'
  else
    assign portrait_classes = portrait_classes | append: ss.aspect_ratio
  endif

  if ss.hover_effect_action != 'no-effect'
    assign portrait_classes = portrait_classes | append: ' ' | append: ss.hover_effect_action
  endif
%}

<div class="{{ first_class }}" id="about-editorial-portrait-{{ section.id }}">
  <div class="{{ container_width }}">
    <div class="inner-section {% if ss.enable_sidebar_space %}sidebar-space{% endif %}">
      <div class="about-editorial-portrait__wrap">
        {% if ss.bg_word_top != blank %}
          <div class="about-editorial-portrait__word about-editorial-portrait__word--top" data-word-top>
            {{ ss.bg_word_top }}
          </div>
        {% endif %}

        {% if ss.bg_word_bottom != blank %}
          <div class="about-editorial-portrait__word about-editorial-portrait__word--bottom" data-word-bottom>
            {{ ss.bg_word_bottom }}
          </div>
        {% endif %}

        <div class="about-editorial-portrait__center" data-portrait-wrap>
          <div class="about-editorial-portrait__media" data-portrait-media>
            {% render 'image',
              class: portrait_classes,
              image: ss.image,
              mobile_image: ss.image_mobile,
              width: 1600,
              img_alt: ss.heading,
              loading: 'lazy'
            %}
          </div>

          <div class="about-editorial-portrait__shape" data-portrait-shape></div>

          <div class="about-editorial-portrait__card text-{{ ss.text_align }}" data-portrait-card>
            {% if ss.subheading != blank %}
              <div class="about-editorial-portrait__eyebrow">
                {{ ss.subheading }}
              </div>
            {% endif %}

            {% if ss.heading != blank %}
              <h2 class="about-editorial-portrait__heading {{ ss.font_size }}">
                {{ ss.heading }}
              </h2>
            {% endif %}

            {% if ss.text != blank %}
              <div class="about-editorial-portrait__text rte">
                {{ ss.text }}
              </div>
            {% endif %}

            {% if ss.button_label != blank and ss.button_link != blank %}
              <div class="about-editorial-portrait__button">
                <a href="{{ ss.button_link }}" class="btn {{ ss.button_style }}">
                  {{ ss.button_label }}
                </a>
              </div>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
.about-editorial-portrait {
  overflow: hidden;
}

.about-editorial-portrait__wrap {
  position: relative;
  min-height: 38rem;
  padding-top: 2rem;
  padding-bottom: 2rem;
}

.about-editorial-portrait__word {
  position: absolute;
  font-family: var(--font-heading-family, sans-serif);
  font-weight: var(--font-heading-weight, 600);
  line-height: 0.85;
  letter-spacing: -0.04em;
  color: rgba(var(--color-heading), 0.12);
  pointer-events: none;
  user-select: none;
  z-index: 1;
  white-space: nowrap;
}

.about-editorial-portrait__word--top {
  top: 0;
  left: 0;
  font-size: clamp(5rem, 13vw, 12rem);
}

.about-editorial-portrait__word--bottom {
  right: 0;
  bottom: 0;
  text-align: right;
  font-size: clamp(4.5rem, 12vw, 11rem);
}

.about-editorial-portrait__center {
  position: relative;
  z-index: 2;
  width: min(100%, 62rem);
  margin: 0 auto;
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 42rem;
}

.about-editorial-portrait__media {
  width: min(100%, 32rem);
  position: relative;
  z-index: 3;
  will-change: transform;
}

.about-editorial-portrait__shape {
  position: absolute;
  width: 9rem;
  height: 9rem;
  border-radius: 50%;
  background: rgba(var(--color-additional-1), 0.12);
  top: 8%;
  right: 8%;
  z-index: 1;
  will-change: transform;
}

.about-editorial-portrait__card {
  position: absolute;
  left: -2rem;
  bottom: 2.5rem;
  width: min(100%, 24rem);
  background: rgb(var(--color-background));
  padding: 1.35rem 1.35rem 1.5rem;
  z-index: 4;
  box-shadow: 0 18px 50px rgba(0, 0, 0, 0.08);
  will-change: transform, opacity;
}

.about-editorial-portrait__eyebrow {
  margin-bottom: 0.6rem;
  font-size: 0.76em;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: rgba(var(--color-heading), 0.62);
}

.about-editorial-portrait__heading {
  margin: 0 0 0.75rem;
  line-height: 1.05;
}

.about-editorial-portrait__text {
  color: rgba(var(--color-text), 0.8);
}

.about-editorial-portrait__text p {
  margin-bottom: 0.9rem;
  line-height: 1.75;
}

.about-editorial-portrait__button {
  margin-top: 1.1rem;
}

@media (min-width: 991px) {
  .about-editorial-portrait__wrap {
    min-height: 48rem;
    padding-top: 3rem;
    padding-bottom: 3rem;
  }

  .about-editorial-portrait__center {
    min-height: 48rem;
  }

  .about-editorial-portrait__media {
    width: min(100%, 34rem);
  }

  .about-editorial-portrait__card {
    left: -5rem;
    bottom: 3rem;
    width: min(100%, 26rem);
    padding: 1.6rem 1.6rem 1.8rem;
  }

  .about-editorial-portrait__shape {
    width: 11rem;
    height: 11rem;
    top: 12%;
    right: 4%;
  }
}

@media (max-width: 990px) {
  .about-editorial-portrait__wrap {
    min-height: auto;
    padding-top: 1rem;
    padding-bottom: 1rem;
  }

  .about-editorial-portrait__center {
    min-height: auto;
    display: block;
    width: min(100%, 34rem);
  }

  .about-editorial-portrait__media {
    width: 100%;
  }

  .about-editorial-portrait__card {
    position: relative;
    left: auto;
    bottom: auto;
    width: calc(100% - 1.5rem);
    margin: -3rem 0 0 1.5rem;
  }

  .about-editorial-portrait__shape {
    width: 7rem;
    height: 7rem;
    top: auto;
    right: 0;
    bottom: 6rem;
  }
}

@media (max-width: 767px) {
  .about-editorial-portrait__word--top {
    font-size: clamp(3.5rem, 16vw, 6rem);
  }

  .about-editorial-portrait__word--bottom {
    font-size: clamp(3rem, 14vw, 5.5rem);
  }

  .about-editorial-portrait__card {
    width: calc(100% - 1rem);
    margin: -2.2rem 0 0 1rem;
    padding: 1rem 1rem 1.15rem;
  }

  .about-editorial-portrait__heading {
    margin-bottom: 0.65rem;
  }

  .about-editorial-portrait__text p {
    line-height: 1.65;
  }
}
{% endstylesheet %}

<script>
  (function() {
    function initAboutEditorialPortrait(sectionId) {
      var section = document.getElementById('about-editorial-portrait-' + sectionId);
      if (!section || section.dataset.gsapInitialized === 'true') return;

      section.dataset.gsapInitialized = 'true';

      if (typeof gsap === 'undefined') return;

      if (typeof ScrollTrigger !== 'undefined' && gsap.registerPlugin) {
        gsap.registerPlugin(ScrollTrigger);
      }

      var wordTop = section.querySelector('[data-word-top]');
      var wordBottom = section.querySelector('[data-word-bottom]');
      var portraitMedia = section.querySelector('[data-portrait-media]');
      var portraitCard = section.querySelector('[data-portrait-card]');
      var portraitShape = section.querySelector('[data-portrait-shape]');

      gsap.set(portraitMedia, {
        opacity: 0,
        y: 60,
        scale: 0.92
      });

      gsap.set(portraitCard, {
        opacity: 0,
        y: 40
      });

      var introTimeline = gsap.timeline({
        scrollTrigger: {
          trigger: section,
          start: 'top 78%',
          once: true
        }
      });

      introTimeline
        .to(portraitMedia, {
          opacity: 1,
          y: 0,
          scale: 1,
          duration: 1.1,
          ease: 'power3.out'
        })
        .to(portraitCard, {
          opacity: 1,
          y: 0,
          duration: 0.8,
          ease: 'power3.out'
        }, '-=0.55');

      if (typeof ScrollTrigger !== 'undefined') {
        if (wordTop) {
          gsap.to(wordTop, {
            xPercent: -10,
            ease: 'none',
            scrollTrigger: {
              trigger: section,
              start: 'top bottom',
              end: 'bottom top',
              scrub: 1
            }
          });
        }

        if (wordBottom) {
          gsap.to(wordBottom, {
            xPercent: 12,
            ease: 'none',
            scrollTrigger: {
              trigger: section,
              start: 'top bottom',
              end: 'bottom top',
              scrub: 1.1
            }
          });
        }

        if (portraitMedia) {
          gsap.to(portraitMedia, {
            yPercent: -8,
            ease: 'none',
            scrollTrigger: {
              trigger: section,
              start: 'top bottom',
              end: 'bottom top',
              scrub: 0.9
            }
          });
        }

        if (portraitCard) {
          gsap.to(portraitCard, {
            yPercent: -12,
            ease: 'none',
            scrollTrigger: {
              trigger: section,
              start: 'top bottom',
              end: 'bottom top',
              scrub: 1
            }
          });
        }

        if (portraitShape) {
          gsap.to(portraitShape, {
            yPercent: 18,
            xPercent: -10,
            ease: 'none',
            scrollTrigger: {
              trigger: section,
              start: 'top bottom',
              end: 'bottom top',
              scrub: 1.2
            }
          });
        }
      }
    }

    document.addEventListener('DOMContentLoaded', function() {
      initAboutEditorialPortrait('{{ section.id }}');
    });

    document.addEventListener('shopify:section:load', function(event) {
      if (event.target && event.target.querySelector('#about-editorial-portrait-{{ section.id }}')) {
        initAboutEditorialPortrait('{{ section.id }}');
      }
    });
  })();
</script>

{% schema %}
{
  "name": "About editorial portrait",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "checkbox",
      "id": "enable_sidebar_space",
      "label": "Enable sidebar space",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme"
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "options": [
        { "value": "container", "label": "Container" },
        { "value": "container-fluid", "label": "Container fluid" },
        { "value": "container-narrow", "label": "Container narrow" },
        { "value": "container-extra-narrow", "label": "Container extra narrow" },
        { "value": "full-width", "label": "Full width" },
        { "value": "extended", "label": "Extended" }
      ],
      "default": "extended"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text align",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "font_size",
      "label": "Heading size",
      "options": [
        { "value": "h1", "label": "h1" },
        { "value": "h2", "label": "h2" },
        { "value": "h3", "label": "h3" },
        { "value": "h4", "label": "h4" }
      ],
      "default": "h3"
    },
    {
      "type": "header",
      "content": "Background words"
    },
    {
      "type": "textarea",
      "id": "bg_word_top",
      "label": "Top word",
      "default": "MEET"
    },
    {
      "type": "textarea",
      "id": "bg_word_bottom",
      "label": "Bottom word",
      "default": "FOUNDER"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "About the founder"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "A refined vision behind the brand."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Introduce the founder, creative director, or brand story with a strong editorial portrait and elegant motion that feels premium and modern.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Read our story"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button style",
      "options": [
        { "value": "btn--primary", "label": "Primary" },
        { "value": "btn--secondary", "label": "Secondary" },
        { "value": "btn--underline", "label": "Underline" }
      ],
      "default": "btn--primary"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Portrait image"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Portrait image mobile"
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Image aspect ratio",
      "options": [
        { "value": "adapt-to-image", "label": "Adapt to image" },
        { "value": "cropped-image--square", "label": "Square" },
        { "value": "cropped-image--portrait", "label": "Portrait" },
        { "value": "cropped-image--portrait-tall", "label": "Portrait tall" },
        { "value": "cropped-image--landscape", "label": "Landscape" },
        { "value": "cropped-image--wide", "label": "Wide" }
      ],
      "default": "cropped-image--portrait-tall"
    },
    {
      "type": "select",
      "id": "hover_effect_action",
      "label": "Image hover effect",
      "options": [
        { "value": "no-effect", "label": "No effect" },
        { "value": "is-hover-zoom-in", "label": "Zoom in" },
        { "value": "is-hover-zoom-out", "label": "Zoom out" },
        { "value": "is-hover-zoom-up", "label": "Zoom up" },
        { "value": "is-hover-fade", "label": "Fade" },
        { "value": "is-hover-cinematic", "label": "Cinematic" },
        { "value": "is-hover-drift", "label": "Drift" },
        { "value": "is-hover-overlay", "label": "Overlay" }
      ],
      "default": "no-effect"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Top padding",
      "default": 70
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Bottom padding",
      "default": 70
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom class"
    },
    {
      "type": "select",
      "id": "color_control",
      "label": "Color Control",
      "options": [
        { "value": "section-dark", "label": "Dark" },
        { "value": "section-light", "label": "Light" }
      ],
      "default": "section-light"
    }
  ],
  "presets": [
    {
      "name": "About editorial portrait"
    }
  ]
}
{% endschema %}