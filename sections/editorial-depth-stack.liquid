{% stylesheet %}
.editorial-depth-stack {
  position: relative;
  overflow: hidden;
  background: rgb(var(--color-background));
}

.editorial-depth-stack__inner {
  display: grid;
  grid-template-columns: 1fr;
  gap: 2.5rem;
  align-items: start;
}

.editorial-depth-stack__content {
  max-width: 42rem;
  position: relative;
  z-index: 5;
}

.editorial-depth-stack__eyebrow {
  margin-bottom: 1rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  font-size: 0.8rem;
  color: rgb(var(--color-subtext));
  opacity: 0.8;
}

.editorial-depth-stack__heading {
  max-width: 12ch;
  margin-bottom: 1.2rem;
}

.editorial-depth-stack__text {
  max-width: 38rem;
}

.editorial-depth-stack__text p {
  color: rgb(var(--color-text));
  opacity: 0.9;
}

.editorial-depth-stack__actions {
  margin-top: 1.75rem;
}

.editorial-depth-stack__media {
  position: relative;
  min-height: 32rem;
}

.editorial-depth-stack__media-stage {
  position: relative;
  min-height: clamp(36rem, 60vw, 48rem);
  padding-top: 0.4rem;
  padding-right: 1rem;
  padding-bottom: 1rem;
  padding-left: 1rem;
}

.editorial-depth-stack__card {
  position: absolute;
  will-change: transform;
  transform: translate3d(0, 0, 0);
}

.editorial-depth-stack__card-media {
  position: relative;
  overflow: hidden;
  background: rgba(var(--color-background-secondary), 1);
  box-shadow: 0 20px 50px rgba(0, 0, 0, 0.1);
}

.editorial-depth-stack__image,
.editorial-depth-stack__image img,
.editorial-depth-stack__card .image {
  display: block;
  width: 100%;
  height: 100%;
}

.editorial-depth-stack__card .image img {
  width: 100%;
  aspect-ratio: 4 / 5;
  object-fit: cover;
}

.editorial-depth-stack__placeholder {
  aspect-ratio: 4 / 5;
  background: rgba(var(--color-background-secondary), 1);
}

.editorial-depth-stack__card-overlay {
  position: absolute;
  left: 1rem;
  right: 1rem;
  bottom: 1rem;
  max-width: calc(100% - 2rem);
  padding: 0.95rem 1rem 0.3rem;
  backdrop-filter: blur(10px);
  background: rgba(var(--color-background), 0.72);
  border-radius: 1rem;
  z-index: 5;
}

.editorial-depth-stack__card-subtitle {
  margin-bottom: 0.35rem;
  font-size: 0.75rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgb(var(--color-subtext));
}

.editorial-depth-stack__card-title {
  margin-bottom: 0.45rem;
}

.editorial-depth-stack__card-link {
  display: inline-flex;
  width: fit-content;
}

.editorial-depth-stack__card--1 {
  top: 0;
  left: 0;
  width: min(64%, 31rem);
  z-index: 1;
}

.editorial-depth-stack__card--1 .editorial-depth-stack__card-overlay {
  top: 1rem;
  bottom: auto;
  right: auto;
  width: max-content;
  max-width: min(16rem, calc(100% - 2rem));
}

.editorial-depth-stack__card--2 {
  top: 0.75rem;
  right: 0;
  width: min(38%, 19rem);
  z-index: 4;
}

.editorial-depth-stack__card--3 {
  top: 48%;
  left: 18%;
  width: min(44%, 22rem);
  z-index: 3;
}

[data-split-reveal],
[data-fade-reveal],
[data-depth-card] {
  opacity: 0;
}

@media (min-width: 992px) {
  .editorial-depth-stack__inner {
    grid-template-columns: minmax(20rem, 0.9fr) minmax(28rem, 1.1fr);
    gap: clamp(2rem, 4vw, 5rem);
    align-items: start;
  }

  .editorial-depth-stack__content {
    position: sticky;
    top: 6.5rem;
    align-self: start;
    padding-top: 1rem;
    padding-bottom: 1rem;
  }

  .editorial-depth-stack__media {
    min-height: clamp(40rem, 64vw, 52rem);
  }

  .editorial-depth-stack__media-stage {
    min-height: clamp(40rem, 64vw, 52rem);
  }
}

@media (min-width: 992px) and (max-width: 1220px) {
  .editorial-depth-stack__card--1 {
    width: min(62%, 28rem);
  }

  .editorial-depth-stack__card--2 {
    width: min(36%, 17rem);
  }

  .editorial-depth-stack__card--3 {
    width: min(42%, 20rem);
    left: 16%;
  }
}

@media (max-width: 991px) {
  .editorial-depth-stack__content {
    max-width: 100%;
  }

  .editorial-depth-stack__media {
    min-height: auto;
  }

  .editorial-depth-stack__media-stage {
    min-height: auto;
    display: grid;
    gap: 1rem;
    padding: 0;
  }

  .editorial-depth-stack__card {
    position: relative;
    inset: auto;
    width: 100%;
    opacity: 1;
    transform: none !important;
  }

  .editorial-depth-stack__card--1 .editorial-depth-stack__card-overlay,
  .editorial-depth-stack__card--2 .editorial-depth-stack__card-overlay,
  .editorial-depth-stack__card--3 .editorial-depth-stack__card-overlay {
    top: auto;
    bottom: 0.85rem;
    left: 0.85rem;
    right: 0.85rem;
    width: auto;
    max-width: none;
  }

  .editorial-depth-stack__card-overlay {
    left: 0.85rem;
    right: 0.85rem;
    bottom: 0.85rem;
    max-width: none;
  }

  [data-split-reveal],
  [data-fade-reveal],
  [data-depth-card] {
    opacity: 1;
  }
}
{% endstylesheet %}
{% javascript %}
(function () {
  const SECTION_SELECTOR = '[data-editorial-depth-stack]';

  function killSectionAnimations(section) {
    if (typeof ScrollTrigger === 'undefined' || typeof gsap === 'undefined') return;

    ScrollTrigger.getAll().forEach((trigger) => {
      const triggerEl = trigger.vars && trigger.vars.trigger;
      if (triggerEl instanceof Element && section.contains(triggerEl)) {
        trigger.kill();
      }
    });

    const animated = section.querySelectorAll(
      '[data-split-reveal], [data-fade-reveal], [data-depth-card], .editorial-depth-stack__card .image img'
    );
    animated.forEach((el) => gsap.killTweensOf(el));
  }

  function initEditorialDepthStack(section) {
    if (!section || typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;

    gsap.registerPlugin(ScrollTrigger);

    if (section._editorialDepthMM) {
      section._editorialDepthMM.revert();
    }

    killSectionAnimations(section);

    const desktopBreakpoint = parseInt(section.dataset.desktopBreakpoint || '991', 10);
    const enableParallax = section.dataset.enableParallax === 'true';

    const splitItems = section.querySelectorAll('[data-split-reveal]');
    const fadeItems = section.querySelectorAll('[data-fade-reveal]');
    const depthCards = section.querySelectorAll('[data-depth-card]');
    const mediaImages = section.querySelectorAll('.editorial-depth-stack__card .image img');

    const mm = gsap.matchMedia();
    section._editorialDepthMM = mm;

    mm.add(`(min-width: ${desktopBreakpoint + 1}px)`, () => {
      gsap.set(splitItems, { autoAlpha: 0, y: 20 });
      gsap.set(fadeItems, { autoAlpha: 0, y: 18 });

      depthCards.forEach((card, index) => {
        gsap.set(card, {
          autoAlpha: 0,
          y: index === 0 ? 12 : 24,
          x: 0,
          rotate: index === 1 ? 1 : index === 2 ? -1 : 0,
          scale: 0.985
        });
      });

      const introTl = gsap.timeline({
        scrollTrigger: {
          trigger: section,
          start: 'top 78%',
          once: true
        }
      });

      introTl.to(splitItems, {
        autoAlpha: 1,
        y: 0,
        duration: 0.6,
        stagger: 0.07,
        ease: 'power3.out'
      });

      introTl.to(fadeItems, {
        autoAlpha: 1,
        y: 0,
        duration: 0.55,
        stagger: 0.06,
        ease: 'power3.out'
      }, '-=0.25');

      introTl.to(depthCards, {
        autoAlpha: 1,
        y: 0,
        scale: 1,
        duration: 0.65,
        stagger: 0.08,
        ease: 'power3.out'
      }, '-=0.3');

      depthCards.forEach((card, index) => {
        const strength = parseInt(card.dataset.depth || '40', 10);

        let fromY = 0;
        let toY = 0;
        let fromX = 0;
        let toX = 0;
        let fromRotate = 0;
        let toRotate = 0;

        if (index === 0) {
          fromY = 0;
          toY = -6;
          fromX = 0;
          toX = -4;
          fromRotate = 0;
          toRotate = -0.4;
        } else if (index === 1) {
          fromY = strength * 0.12;
          toY = strength * -0.25;
          fromX = 8;
          toX = -10;
          fromRotate = 1;
          toRotate = -1;
        } else if (index === 2) {
          fromY = strength * 0.16;
          toY = strength * -0.3;
          fromX = -6;
          toX = 8;
          fromRotate = -1;
          toRotate = 0.8;
        }

        gsap.fromTo(card, {
          y: fromY,
          x: fromX,
          rotate: fromRotate
        }, {
          y: toY,
          x: toX,
          rotate: toRotate,
          ease: 'none',
          scrollTrigger: {
            trigger: section,
            start: 'top bottom-=10%',
            end: 'bottom top+=10%',
            scrub: 0.8,
            invalidateOnRefresh: true
          }
        });
      });

      if (enableParallax) {
        mediaImages.forEach((img, index) => {
          const yTo = index === 0 ? 5 : index === 1 ? 10 : 12;

          gsap.fromTo(img, {
            yPercent: -2,
            scale: 1.01
          }, {
            yPercent: yTo,
            scale: 1.03,
            ease: 'none',
            scrollTrigger: {
              trigger: section,
              start: 'top bottom',
              end: 'bottom top',
              scrub: 0.9,
              invalidateOnRefresh: true
            }
          });
        });
      }

      ScrollTrigger.refresh();
    });

    mm.add(`(max-width: ${desktopBreakpoint}px)`, () => {
      gsap.set([...splitItems, ...fadeItems, ...depthCards], {
        autoAlpha: 1,
        clearProps: 'transform'
      });

      splitItems.forEach((item, index) => {
        gsap.fromTo(item, {
          autoAlpha: 0,
          y: 16
        }, {
          autoAlpha: 1,
          y: 0,
          duration: 0.45,
          ease: 'power2.out',
          delay: index * 0.04,
          scrollTrigger: {
            trigger: item,
            start: 'top 92%',
            once: true
          }
        });
      });

      fadeItems.forEach((item) => {
        gsap.fromTo(item, {
          autoAlpha: 0,
          y: 14
        }, {
          autoAlpha: 1,
          y: 0,
          duration: 0.45,
          ease: 'power2.out',
          scrollTrigger: {
            trigger: item,
            start: 'top 92%',
            once: true
          }
        });
      });

      depthCards.forEach((card, index) => {
        gsap.fromTo(card, {
          autoAlpha: 0,
          y: 18
        }, {
          autoAlpha: 1,
          y: 0,
          duration: 0.5,
          ease: 'power2.out',
          delay: index * 0.05,
          scrollTrigger: {
            trigger: card,
            start: 'top 94%',
            once: true
          }
        });
      });

      ScrollTrigger.refresh();
    });
  }

  function initAllEditorialDepthStacks(scope) {
    const root = scope || document;
    root.querySelectorAll(SECTION_SELECTOR).forEach(initEditorialDepthStack);
  }

  document.addEventListener('DOMContentLoaded', function () {
    initAllEditorialDepthStacks(document);
  });

  document.addEventListener('shopify:section:load', function (event) {
    initAllEditorialDepthStacks(event.target);
  });

  document.addEventListener('shopify:section:reorder', function () {
    initAllEditorialDepthStacks(document);
  });
})();
{% endjavascript %}
{% render 'section-base-style' %}

{%- liquid
  assign outer_classes = 'editorial-depth-stack'
  assign outer_classes = outer_classes | append: ' section-' | append: section.id | append: '-padding'
  assign outer_classes = outer_classes | append: ' m-color-' | append: section.settings.color_scheme
  assign outer_classes = outer_classes | append: ' ' | append: section.settings.custom_class
  assign outer_classes = outer_classes | append: ' ' | append: section.settings.color_control

  assign inner_classes = section.settings.container_width
-%}

<section
  class="{{ outer_classes }}"
  id="EditorialDepthStack-{{ section.id }}"
  data-section-id="{{ section.id }}"
  data-editorial-depth-stack
  data-enable-pin="{{ section.settings.enable_pin }}"
  data-enable-parallax="{{ section.settings.enable_parallax }}"
  data-desktop-breakpoint="991"
  {{ section.shopify_attributes }}
>
  <div class="{{ inner_classes }}">
    <div class="sidebar-space">
      <div class="editorial-depth-stack__inner">
        <div class="editorial-depth-stack__content" data-editorial-content>
          {% if section.settings.eyebrow != blank %}
            <p class="editorial-depth-stack__eyebrow" data-split-reveal>
              {{ section.settings.eyebrow }}
            </p>
          {% endif %}

          {% if section.settings.heading != blank %}
            <h2 class="editorial-depth-stack__heading {{ section.settings.heading_size }}" data-split-reveal>
              {{ section.settings.heading }}
            </h2>
          {% endif %}

          {% if section.settings.text != blank %}
            <div class="editorial-depth-stack__text rte" data-fade-reveal>
              {{ section.settings.text }}
            </div>
          {% endif %}

          {% if section.settings.button_label != blank and section.settings.button_link != blank %}
            <div class="editorial-depth-stack__actions" data-fade-reveal>
              <a href="{{ section.settings.button_link }}" class="btn btn--primary">
                {{ section.settings.button_label }}
              </a>
            </div>
          {% endif %}
        </div>

        <div class="editorial-depth-stack__media" data-editorial-media>
          <div class="editorial-depth-stack__media-stage">
            {% for block in section.blocks %}
              {%- liquid
                assign image = block.settings.image
                assign mobile_image = block.settings.mobile_image
                assign card_link = block.settings.link
              -%}

              <article
                class="editorial-depth-stack__card editorial-depth-stack__card--{{ forloop.index }}"
                data-depth-card
                data-depth="{{ block.settings.depth_strength }}"
                {{ block.shopify_attributes }}
              >
                <div class="editorial-depth-stack__card-media border-radius-style-two">
                  {% if image != blank %}
                    {% render 'image',
                      image: image,
                      mobile_image: mobile_image,
                      class: 'editorial-depth-stack__image',
                      img_alt: block.settings.title,
                      loading: 'lazy',
                      fetchpriority: 'low'
                    %}
                  {% else %}
                    <div class="editorial-depth-stack__placeholder"></div>
                  {% endif %}
                </div>

                {% if block.settings.subtitle != blank or block.settings.title != blank or block.settings.link_label != blank %}
                  <div class="editorial-depth-stack__card-overlay">
                    {% if block.settings.subtitle != blank %}
                      <p class="editorial-depth-stack__card-subtitle">{{ block.settings.subtitle }}</p>
                    {% endif %}

                    {% if block.settings.title != blank %}
                      <h3 class="editorial-depth-stack__card-title h5">{{ block.settings.title }}</h3>
                    {% endif %}

                    {% if block.settings.link_label != blank and card_link != blank %}
                      <a href="{{ card_link }}" class="editorial-depth-stack__card-link">
                        <span class="hover-underline">{{ block.settings.link_label }}</span>
                      </a>
                    {% endif %}
                  </div>
                {% endif %}
              </article>
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>


{% schema %}
{
  "name": "Editorial depth stack",
  "tag": "section",
  "class": "shopify-section-editorial-depth-stack",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme"
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "options": [
        { "value": "container", "label": "Container" },
        { "value": "container-fluid", "label": "Container fluid" },
        { "value": "container-narrow", "label": "Container narrow" },
        { "value": "container-extra-narrow", "label": "Container extra narrow" },
        { "value": "extended", "label": "Extended" },
        { "value": "full-width", "label": "Full width" }
      ],
      "default": "container-fluid"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Editorial motion"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "A layered scroll composition with depth, movement, and premium pacing."
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ],
      "default": "h2"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Use this section to create an elevated campaign story. The content stays calm while the layered images shift with scroll for a more immersive editorial feel.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Explore now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "checkbox",
      "id": "enable_pin",
      "label": "Enable desktop pinning",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_parallax",
      "label": "Enable layered parallax",
      "default": true
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom class"
    },
    {
      "type": "select",
      "id": "color_control",
      "label": "Color control",
      "options": [
        { "value": "section-dark", "label": "Dark" },
        { "value": "section-light", "label": "Light" }
      ],
      "default": "section-light"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "layer",
      "name": "Layer card",
      "limit": 3,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Desktop image"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile image"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Collection"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Layer title"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label",
          "default": "Shop this"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "range",
          "id": "depth_strength",
          "label": "Depth strength",
          "min": 10,
          "max": 120,
          "step": 2,
          "default": 40,
          "unit": "px"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Editorial depth stack",
      "blocks": [
        {
          "type": "layer",
          "settings": {
            "subtitle": "Look 01",
            "title": "Soft tailoring"
          }
        },
        {
          "type": "layer",
          "settings": {
            "subtitle": "Look 02",
            "title": "Layered neutrals",
            "depth_strength": 70
          }
        },
        {
          "type": "layer",
          "settings": {
            "subtitle": "Look 03",
            "title": "Quiet statement",
            "depth_strength": 100
          }
        }
      ]
    }
  ]
}
{% endschema %}