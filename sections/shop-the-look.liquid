{% render 'section-base-style' %}

{%- liquid
  assign classes = 'shop-the-look'
  assign classes = classes | append: ' section-' | append: section.id | append: '-padding'
  assign classes = classes | append: ' ' | append: section.settings.color_control
  assign classes = classes | append: ' m-color-' | append: section.settings.color_scheme
  unless section.settings.container_type == "full-width"
    assign classes = classes | append: ' section-x-padding'
  endunless
  assign classes = classes | append: ' ' | append: section.settings.custom_class | default: ''
  assign image_classes = 'cropped-image-wrapper'
  assign image_classes = image_classes | append: ' ' | append: section.settings.aspect_ratio
-%}

{% stylesheet %}
  .shop-the-look {
    position: relative;
    overflow: hidden;
  }

  .shop-the-look__inner {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr);
    gap: clamp(2rem, 5vw, 6rem);
    align-items: center;
  }

  .shop-the-look__media {
    position: relative;
  }

  .shop-the-look__image {
    position: relative;
  }

  .shop-the-look__image .cropped-image-wrapper {
    overflow: hidden;
  }

  .shop-the-look__content {
    max-width: 34rem;
  }
  .space-right{
    padding-right: 4rem;
  }
  .shop-the-look__eyebrow {
    display: inline-block;
    margin-bottom: 1rem;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    opacity: 0.8;
  }

  .shop-the-look__heading {
    margin: 0 0 1.2rem;
  }

  .shop-the-look__text {
    margin-bottom: 1.8rem;
    max-width: 32rem;
  }

  .shop-the-look__products {
    margin: 0 0 2rem;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.9rem;
  }

  .shop-the-look__product {
    border-top: 1px solid rgb(var(--color-border));
    padding-top: 0.9rem;
  }

  .shop-the-look__product:first-child {
    border-top: 0;
    padding-top: 0;
  }

  .shop-the-look__product-link {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 0.9rem;
    align-items: center;
    text-decoration: none;
    color: inherit;
  }

  .shop-the-look__product-thumb {
    width: 4.5rem;
    min-width: 4.5rem;
  }

  .shop-the-look__product-thumb .cropped-image-wrapper {
    overflow: hidden;
  }

  .shop-the-look__product-title {
    margin: 0;
    color: rgb(var(--color-heading));
    line-height: 1.3;
  }

  .shop-the-look__product-price {
    color: rgb(var(--color-price-regular));
    white-space: nowrap;
  }

  .shop-the-look__button .icon {
    margin-left: 1.25rem;
    margin-bottom: -2px;
    transition: transform 0.3s ease;
  }

  .rtl .shop-the-look__button .icon {
    margin-left: 0;
    margin-right: 1.25rem;
  }

  .shop-the-look__button:hover .icon {
    transform: translateX(4px);
  }

  .rtl .shop-the-look__button:hover .icon {
    transform: translateX(-4px);
  }

  /* Hotspots */
  .shop-the-look__hotspot {
    position: absolute;
    transform: translate(-50%, -50%);
    z-index: 3;
  }

  .shop-the-look__hotspot-button {
    width: 1.9rem;
    height: 1.9rem;
    border-radius: 50%;
    background: rgb(var(--color-background));
    color: rgb(var(--color-heading));
    border: 1px solid rgba(0, 0, 0, 0.08);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.14);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    position: relative;
    transition: transform 0.25s ease;
  }

  .shop-the-look__hotspot-button::before,
  .shop-the-look__hotspot-button::after {
    content: "";
    position: absolute;
    background: currentColor;
  }

  .shop-the-look__hotspot-button::before {
    width: 0.7rem;
    height: 1px;
  }

  .shop-the-look__hotspot-button::after {
    width: 1px;
    height: 0.7rem;
  }

  .shop-the-look__hotspot-button:hover {
    transform: scale(1.08);
  }

  .shop-the-look__hotspot-pulse {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.7);
    animation: shopTheLookPulse 2.4s ease-out infinite;
    pointer-events: none;
  }

  @keyframes shopTheLookPulse {
    0% {
      transform: scale(1);
      opacity: 0.9;
    }
    100% {
      transform: scale(1.9);
      opacity: 0;
    }
  }

  @media (max-width: 991px) {
    .shop-the-look__inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .shop-the-look__content {
      max-width: 100%;
    }

    .shop-the-look__product-link {
      grid-template-columns: 4rem 1fr;
    }

    .shop-the-look__product-price {
      grid-column: 2;
    }
  }
{% endstylesheet %}

<section
  class="{{ classes }}"
  data-shop-the-look
  data-section-id="{{ section.id }}"
>
  <div class="{{ section.settings.container_type }} {% if section.settings.enable_sidebar_space %}sidebar-space{% endif %}">
    <div class="shop-the-look__inner">
      <div class="shop-the-look__media" data-look-media>
        <div class="shop-the-look__image">
          {% render 'image',
            image: section.settings.look_image,
            class: image_classes,
            img_alt: section.settings.heading
          %}

          {% for block in section.blocks %}
            {% assign product = all_products[block.settings.product] %}
            {% if product != blank %}
              <div
                class="shop-the-look__hotspot"
                style="top: {{ block.settings.top_position }}%; left: {{ block.settings.left_position }}%;"
                {{ block.shopify_attributes }}
              >
                <a
                  href="{{ product.url }}"
                  class="shop-the-look__hotspot-button"
                  aria-label="{{ product.title }}"
                >
                  <span class="shop-the-look__hotspot-pulse"></span>
                </a>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>

      <div class="shop-the-look__content {%  unless section.settings.container_type == "full-width" %}space-right{% endunless %}">
        {% if section.settings.eyebrow != blank %}
          <span class="shop-the-look__eyebrow h6" data-look-text>
            {{ section.settings.eyebrow }}
          </span>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h2 class="shop-the-look__heading {{ section.settings.heading_size }}" data-look-text>
            {{ section.settings.heading }}
          </h2>
        {% endif %}

        {% if section.settings.text != blank %}
          <div class="shop-the-look__text rte" data-look-text>
            {{ section.settings.text }}
          </div>
        {% endif %}

        {% assign has_products = false %}
        <ul class="shop-the-look__products">
          {% for block in section.blocks %}
            {% assign product = all_products[block.settings.product] %}
            {% if product != blank %}
              {% assign has_products = true %}
              <li class="shop-the-look__product" data-look-text {{ block.shopify_attributes }}>
                <a href="{{ product.url }}" class="shop-the-look__product-link">
                  <div class="shop-the-look__product-thumb">
                    {% if product.featured_image %}
                      {% render 'image',
                        image: product.featured_image,
                        class: 'cropped-image-wrapper cropped-image--square',
                        img_alt: product.title
                      %}
                    {% endif %}
                  </div>

                  <div class="shop-the-look__product-info">
                    <p class="shop-the-look__product-title">{{ product.title }}</p>
                  </div>

                  <div class="shop-the-look__product-price">
                    {{ product.price | money }}
                  </div>
                </a>
              </li>
            {% endif %}
          {% endfor %}
        </ul>

        {% if section.settings.button_label != blank and section.settings.button_link != blank %}
          <a href="{{ section.settings.button_link }}" class="btn btn-arrow shop-the-look__button" data-look-text>
            <span>{{ section.settings.button_label }}</span>
            <span class="icon">
              {% render 'theme-icon', icon: 'right-arrow' %}
            </span>
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', initShopTheLook);
  document.addEventListener('shopify:section:load', initShopTheLook);

  function initShopTheLook() {
    if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;

    gsap.registerPlugin(ScrollTrigger);

    document.querySelectorAll('[data-shop-the-look][data-section-id="{{ section.id }}"]').forEach((section) => {
      if (section.dataset.lookInit === 'true') return;
      section.dataset.lookInit = 'true';

      const media = section.querySelector('[data-look-media]');
      const textItems = section.querySelectorAll('[data-look-text]');
      const hotspots = section.querySelectorAll('.shop-the-look__hotspot');

      if (media) {
        gsap.set(media, {
          opacity: 0,
          y: 40,
        });
      }

      if (textItems.length) {
        gsap.set(textItems, {
          opacity: 0,
          y: 24,
        });
      }

      if (hotspots.length) {
        gsap.set(hotspots, {
          opacity: 0,
          scale: 0.8,
        });
      }

      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: section,
          start: 'top 82%',
          once: true,
        },
      });

      if (media) {
        tl.to(media, {
          opacity: 1,
          y: 0,
          duration: 0.9,
          ease: 'power3.out',
        });
      }

      if (textItems.length) {
        tl.to(
          textItems,
          {
            opacity: 1,
            y: 0,
            duration: 0.6,
            ease: 'power3.out',
            stagger: 0.12,
          },
          '-=0.45'
        );
      }

      if (hotspots.length) {
        tl.to(
          hotspots,
          {
            opacity: 1,
            scale: 1,
            duration: 0.4,
            ease: 'back.out(1.6)',
            stagger: 0.08,
          },
          '-=0.35'
        );
      }
    });
  }
</script>

{% schema %}
{
  "name": "Shop the Look",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1"
    },
    {
      "type": "select",
      "id": "container_type",
      "label": "Container width",
      "options": [
        { "value": "container", "label": "Container" },
        { "value": "container-fluid", "label": "Container fluid" },
        { "value": "container-narrow", "label": "Container narrow" },
        { "value": "container-extra-narrow", "label": "Container extra narrow" },
        { "value": "extended", "label": "Extended" },
        { "value": "full-width", "label": "Full width" }
      ],
      "default": "container-fluid"
    },
    {
      "type": "checkbox",
      "id": "enable_sidebar_space",
      "label": "Enable Sidebar Space",
      "default": false
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Shop the look"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Curated for effortless dressing"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ],
      "default": "h2"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Highlight a complete look and guide customers to the exact products featured in the image.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Explore collection"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "image_picker",
      "id": "look_image",
      "label": "Look image"
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Aspect Ratio",
      "options": [
        {
          "value": "cropped-image--square",
          "label": "square"
        },
        {
          "value": "cropped-image--portrait",
          "label": "portrait"
        },
        {
          "value": "cropped-image--portrait-tall",
          "label": "portrait-tall"
        },
        {
          "value": "cropped-image--landscape",
          "label": "landscape"
        },
        {
          "value": "cropped-image--wide",
          "label": "wide"
        }
      ],
      "default": "cropped-image--square"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 140,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 140,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 48
    },
    {
      "type": "header",
      "content": "Dynamic option"
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom class"
    },
    {
      "type": "select",
      "id": "color_control",
      "label": "Color control",
      "options": [
        { "value": "section-dark", "label": "Dark" },
        { "value": "section-light", "label": "Light" }
      ],
      "default": "section-light"
    }
  ],
  "blocks": [
    {
      "type": "product_hotspot",
      "name": "Product hotspot",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "range",
          "id": "top_position",
          "label": "Top position",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 40
        },
        {
          "type": "range",
          "id": "left_position",
          "label": "Left position",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 50
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Shop the Look",
      "blocks": [{ "type": "product_hotspot" }, { "type": "product_hotspot" }]
    }
  ]
}
{% endschema %}
