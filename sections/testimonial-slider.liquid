{{ 'swiper-bundle.min.css' | asset_url | stylesheet_tag }}
{% render 'section-base-style' %}

{%- liquid
  assign classes = 'testimonial-editorial-slider'
  unless section.settings.container_width == 'full-width'
    assign classes = classes | append: ' section-x-padding'
  endunless
  assign classes = classes | append: ' section-' | append: section.id | append: '-padding'
  assign classes = classes | append: ' m-color-' | append: section.settings.color_scheme
  assign classes = classes | append: ' ' | append: section.settings.custom_class
  assign classes = classes | append: ' ' | append: section.settings.color_control
-%}

{% stylesheet %}
  .testimonial-editorial-slider {
    position: relative;
    overflow: hidden;
    background: rgb(var(--color-background));
  }

  .testimonial-editorial-slider__header {
    display: grid;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .testimonial-editorial-slider__eyebrow {
    margin: 0;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-size: 0.78rem;
    color: rgb(var(--color-subtext));
    opacity: 0.85;
  }

  .testimonial-editorial-slider__heading {
    margin: 0;
    max-width: 12ch;
  }

  .testimonial-editorial-slider__text {
    max-width: 40rem;
  }

  .testimonial-editorial-slider__text p {
    color: rgb(var(--color-text));
    opacity: 0.9;
  }

  .testimonial-editorial-slider__slider-wrap {
    position: relative;
  }

  .testimonial-editorial-slider__slider {
    overflow: hidden;
  }

  .testimonial-editorial-slider__track {
    align-items: stretch;
  }

  .testimonial-editorial-slider__slide {
    height: auto;
  }

  .testimonial-editorial-slider__card {
    position: relative;
    height: 100%;
    display: grid;
    grid-template-columns: 1fr;
    overflow: hidden;
    background: linear-gradient(
      180deg,
      rgba(var(--color-background-secondary), 0.96) 0%,
      rgba(var(--color-background-secondary), 1) 100%
    );
    border: 1px solid rgba(var(--color-border), 0.5);
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.08);
    transition: transform 0.45s ease, box-shadow 0.45s ease;
  }

  .testimonial-editorial-slider__card:hover {
    transform: translateY(-6px);
    box-shadow: 0 28px 68px rgba(0, 0, 0, 0.12);
  }

  .testimonial-editorial-slider__media {
    position: relative;
    min-height: 24rem;
    overflow: hidden;
    background: rgba(var(--color-border), 0.15);
  }

  .testimonial-editorial-slider__media::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.02) 0%,
      rgba(0, 0, 0, 0.12) 100%
    );
    pointer-events: none;
    z-index: 1;
  }

  .testimonial-editorial-slider__media .image,
  .testimonial-editorial-slider__media .cropped-image-wrapper,
  .testimonial-editorial-slider__media picture,
  .testimonial-editorial-slider__media img {
    display: block;
    width: 100%;
    height: 100%;
  }

  .testimonial-editorial-slider__media img {
    object-fit: cover;
    transition: transform 0.8s cubic-bezier(0, 0, 0.2, 1);
  }

  .testimonial-editorial-slider__card:hover .testimonial-editorial-slider__media img {
    transform: scale(1.05);
  }

  .testimonial-editorial-slider__content {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 1.35rem;
    padding: 1.35rem;
  }

  .testimonial-editorial-slider__quote-mark {
    line-height: 1;
    font-size: clamp(2.5rem, 4vw, 4rem);
    color: rgba(var(--color-heading), 0.16);
    font-family: var(--font-heading-family);
    margin-bottom: -0.6rem;
  }

  .testimonial-editorial-slider__stars {
    display: inline-flex;
    align-items: center;
    gap: 0.28rem;
    color: rgb(var(--color-heading));
    font-size: 0.95rem;
  }

  .testimonial-editorial-slider__quote {
    margin: 0;
    color: rgb(var(--color-heading));
    line-height: 1.45;
  }

  .testimonial-editorial-slider__footer {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    padding-top: 0.2rem;
    border-top: 1px solid rgba(var(--color-border), 0.45);
  }

  .testimonial-editorial-slider__avatar {
    width: 3rem;
    height: 3rem;
    flex: 0 0 auto;
    overflow: hidden;
    border-radius: 50%;
    background: rgba(var(--color-border), 0.18);
  }

  .testimonial-editorial-slider__avatar .image,
  .testimonial-editorial-slider__avatar picture,
  .testimonial-editorial-slider__avatar img {
    width: 100%;
    height: 100%;
    display: block;
  }

  .testimonial-editorial-slider__avatar img {
    object-fit: cover;
  }

  .testimonial-editorial-slider__meta {
    display: grid;
    gap: 0.15rem;
  }

  .testimonial-editorial-slider__name {
    margin: 0;
    color: rgb(var(--color-heading));
  }

  .testimonial-editorial-slider__role {
    margin: 0;
    color: rgb(var(--color-subtext));
    font-size: 0.92rem;
  }

  .testimonial-editorial-slider__nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 1.4rem;
  }

  .testimonial-editorial-slider__arrows {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
  }

  .testimonial-editorial-slider__arrow {
    width: 3rem;
    height: 3rem;
    border: 1px solid rgba(var(--color-border), 0.75);
    background: rgba(var(--color-background-secondary), 0.65);
    color: rgb(var(--color-heading));
    display: inline-flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(8px);
    transition: all 0.25s ease;
  }

  .testimonial-editorial-slider__arrow:hover {
    background: rgb(var(--color-heading));
    color: rgb(var(--color-background));
    border-color: rgb(var(--color-heading));
  }

  .testimonial-editorial-slider__arrow.swiper-button-disabled {
    opacity: 0.35;
    pointer-events: none;
  }

  .testimonial-editorial-slider__pagination {
    position: static;
    display: flex;
    justify-content: flex-end;
    gap: 0.42rem;
  }

  .testimonial-editorial-slider__pagination .swiper-pagination-bullet {
    margin: 0 !important;
    width: 0.55rem;
    height: 0.55rem;
    opacity: 1;
    background: rgba(var(--color-border), 0.9);
  }

  .testimonial-editorial-slider__pagination .swiper-pagination-bullet-active {
    background: rgb(var(--color-heading));
    transform: scale(1.15);
  }

  @media (min-width: 992px) {
    .testimonial-editorial-slider__header {
      grid-template-columns: minmax(18rem, 0.72fr) minmax(20rem, 1fr);
      align-items: end;
      gap: 2rem;
      margin-bottom: 2.5rem;
    }

    .testimonial-editorial-slider__content {
      padding: 1.5rem;
    }

    .testimonial-editorial-slider__quote {
      font-size: 1.08rem;
    }

    .testimonial-editorial-slider__media {
      min-height: 26rem;
    }
  }

  @media (min-width: 1321px) {
    .testimonial-editorial-slider__media {
      min-height: 28rem;
    }
  }

  @media (max-width: 767px) {
    .testimonial-editorial-slider__media {
      min-height: 18rem;
    }

    .testimonial-editorial-slider__content {
      padding: 1.15rem;
    }

    .testimonial-editorial-slider__arrow {
      width: 2.7rem;
      height: 2.7rem;
    }
  }
{% endstylesheet %}

<section
  class="{{ classes }}"
  id="TestimonialEditorialSlider-{{ section.id }}"
  data-testimonial-editorial-slider
  data-section-id="{{ section.id }}"
  {{ section.shopify_attributes }}
>
  <div class="{{ section.settings.container_width }}">
    <div class="{% if section.settings.enable_sidebar_space %}sidebar-space{% endif %}">
      {% if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.text != blank %}
        <div class="testimonial-editorial-slider__header">
          <div>
            {% if section.settings.eyebrow != blank %}
              <p class="testimonial-editorial-slider__eyebrow">{{ section.settings.eyebrow }}</p>
            {% endif %}

            {% if section.settings.heading != blank %}
              <h2 class="testimonial-editorial-slider__heading {{ section.settings.heading_size }}">
                {{ section.settings.heading }}
              </h2>
            {% endif %}
          </div>

          {% if section.settings.text != blank %}
            <div class="testimonial-editorial-slider__text rte">
              {{ section.settings.text }}
            </div>
          {% endif %}
        </div>
      {% endif %}

      <div class="testimonial-editorial-slider__slider-wrap">
        <div
          class="testimonial-editorial-slider__slider swiper"
          data-testimonial-editorial-swiper
          data-autoplay="{{ section.settings.enable_autoplay }}"
          data-autoplay-speed="{{ section.settings.autoplay_speed | times: 1000 }}"
        >
          <div class="testimonial-editorial-slider__track swiper-wrapper">
            {% for block in section.blocks %}
              <div class="testimonial-editorial-slider__slide swiper-slide" {{ block.shopify_attributes }}>
                <article class="testimonial-editorial-slider__card border-radius-style-two">
                  <div class="testimonial-editorial-slider__media">
                    {% if block.settings.image != blank %}
                      {% render 'image',
                        image: block.settings.image,
                        class: 'cropped-image-wrapper cropped-image--portrait',
                        img_alt: block.settings.name,
                        loading: 'lazy',
                        fetchpriority: 'low'
                      %}
                    {% else %}
                      {% render 'image',
                        image: block.settings.avatar,
                        class: 'cropped-image-wrapper cropped-image--portrait',
                        img_alt: block.settings.name,
                        loading: 'lazy',
                        fetchpriority: 'low'
                      %}
                    {% endif %}
                  </div>

                  <div class="testimonial-editorial-slider__content">
                    <div>
                      <div class="testimonial-editorial-slider__quote-mark">“</div>

                      {% if block.settings.show_stars %}
                        <div class="testimonial-editorial-slider__stars" aria-label="5 star rating">
                          <span>★</span>
                          <span>★</span>
                          <span>★</span>
                          <span>★</span>
                          <span>★</span>
                        </div>
                      {% endif %}

                      {% if block.settings.quote != blank %}
                        <blockquote class="testimonial-editorial-slider__quote {{ block.settings.quote_size }}">
                          {{ block.settings.quote }}
                        </blockquote>
                      {% endif %}
                    </div>

                    <div class="testimonial-editorial-slider__footer">
                      {% if block.settings.avatar != blank %}
                        <div class="testimonial-editorial-slider__avatar">
                          {% render 'image',
                            image: block.settings.avatar,
                            img_alt: block.settings.name,
                            loading: 'lazy',
                            fetchpriority: 'low'
                          %}
                        </div>
                      {% endif %}

                      <div class="testimonial-editorial-slider__meta">
                        {% if block.settings.name != blank %}
                          <h3 class="testimonial-editorial-slider__name h6">{{ block.settings.name }}</h3>
                        {% endif %}

                        {% if block.settings.role != blank %}
                          <p class="testimonial-editorial-slider__role">{{ block.settings.role }}</p>
                        {% endif %}
                      </div>
                    </div>
                  </div>
                </article>
              </div>
            {% endfor %}
          </div>
        </div>

        <div class="testimonial-editorial-slider__nav">
          <div class="testimonial-editorial-slider__arrows">
            <button
              type="button"
              class="testimonial-editorial-slider__arrow testimonial-editorial-slider__arrow--prev"
              aria-label="Previous testimonial"
              data-testimonial-editorial-prev
            >
              &#8592;
            </button>
            <button
              type="button"
              class="testimonial-editorial-slider__arrow testimonial-editorial-slider__arrow--next"
              aria-label="Next testimonial"
              data-testimonial-editorial-next
            >
              &#8594;
            </button>
          </div>

          <div class="testimonial-editorial-slider__pagination" data-testimonial-editorial-pagination></div>
        </div>
      </div>
    </div>
  </div>
</section>

<script src="{{ 'swiper-bundle.min.js' | asset_url }}" defer></script>
<script>
  (function () {
    function initTestimonialEditorialSlider(scope) {
      if (typeof Swiper === 'undefined') return;

      const sections = scope.querySelectorAll('[data-testimonial-editorial-slider]');

      sections.forEach((section) => {
        const slider = section.querySelector('[data-testimonial-editorial-swiper]');
        if (!slider) return;

        if (slider.swiper) {
          slider.swiper.destroy(true, true);
        }

        const autoplayEnabled = slider.dataset.autoplay === 'true';
        const autoplaySpeed = parseInt(slider.dataset.autoplaySpeed || '5000', 10);

        new Swiper(slider, {
          slidesPerView: 1.1,
          spaceBetween: 16,
          speed: 900,
          loop: section.querySelectorAll('.swiper-slide').length > 1,
          watchOverflow: true,
          grabCursor: true,
          autoplay: autoplayEnabled
            ? {
                delay: autoplaySpeed,
                disableOnInteraction: false,
                pauseOnMouseEnter: true
              }
            : false,
          pagination: {
            el: section.querySelector('[data-testimonial-editorial-pagination]'),
            clickable: true
          },
          navigation: {
            nextEl: section.querySelector('[data-testimonial-editorial-next]'),
            prevEl: section.querySelector('[data-testimonial-editorial-prev]')
          },
          breakpoints: {
            768: {
              slidesPerView: 2,
              spaceBetween: 20
            },
            992: {
              slidesPerView: 2.2,
              spaceBetween: 24
            },
            1321: {
              slidesPerView: 3,
              spaceBetween: 24
            }
          }
        });
      });
    }

    document.addEventListener('DOMContentLoaded', function () {
      initTestimonialEditorialSlider(document);
    });

    document.addEventListener('shopify:section:load', function (event) {
      initTestimonialEditorialSlider(event.target);
    });

    document.addEventListener('shopify:section:reorder', function () {
      initTestimonialEditorialSlider(document);
    });
  })();
</script>

{% schema %}
{
  "name": "Testimonial slider",
  "tag": "section",
  "class": "shopify-section-testimonial-editorial-slider",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme"
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "options": [
        { "value": "container", "label": "Container" },
        { "value": "container-fluid", "label": "Container fluid" },
        { "value": "container-narrow", "label": "Container narrow" },
        { "value": "container-extra-narrow", "label": "Container extra narrow" },
        { "value": "extended", "label": "Extended" },
        { "value": "full-width", "label": "Full width" }
      ],
      "default": "container-fluid"
    },
    {
      "type": "checkbox",
      "id": "enable_sidebar_space",
      "label": "Enable sidebar space",
      "default": false
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Testimonials"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "What clients are saying"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ],
      "default": "h2"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Add real customer feedback to build trust with a clean editorial slider.</p>"
    },
    {
      "type": "checkbox",
      "id": "enable_autoplay",
      "label": "Enable autoplay",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 2,
      "max": 10,
      "step": 1,
      "unit": "s",
      "label": "Autoplay speed",
      "default": 5
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom class"
    },
    {
      "type": "select",
      "id": "color_control",
      "label": "Color control",
      "options": [
        { "value": "section-dark", "label": "Dark" },
        { "value": "section-light", "label": "Light" }
      ],
      "default": "section-light"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "limit": 12,
      "settings": [
        {
          "type": "checkbox",
          "id": "show_stars",
          "label": "Show stars",
          "default": true
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "Beautiful product quality and a very premium shopping experience. Everything feels thoughtful and refined."
        },
        {
          "type": "select",
          "id": "quote_size",
          "label": "Quote size",
          "options": [
            { "value": "h4", "label": "Extra large" },
            { "value": "h5", "label": "Large" },
            { "value": "h6", "label": "Medium" },
            { "value": "", "label": "Default" }
          ],
          "default": "h5"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Main slide image"
        },
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "Avatar"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Client name"
        },
        {
          "type": "text",
          "id": "role",
          "label": "Role / location",
          "default": "Verified customer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonial slider",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "name": "Sophia Rahman",
            "role": "Verified customer"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "name": "Ariana Malik",
            "role": "Returning customer"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "name": "Nadia Karim",
            "role": "Dubai"
          }
        }
      ]
    }
  ]
}
{% endschema %}