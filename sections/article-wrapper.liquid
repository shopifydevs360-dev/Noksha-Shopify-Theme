{% render 'section-base-style' %}
{% stylesheet %}
  .featured-posts .articles-wrapper {
    position: relative;
    overflow: hidden;
  }

  .featured-posts .article-track {
    position: relative;
    height: clamp(30rem, 50vh, 66rem);
  }

  .featured-posts .article-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    pointer-events: none;
    visibility: hidden;
  }

  .featured-posts .article-slide.is-active {
    opacity: 1;
    pointer-events: auto;
    visibility: visible;
  }

  .featured-posts h1 {
    margin-top: clamp(5rem, 7vh, 6.3rem);
    margin-bottom: clamp(3rem, 5vh, 4.3rem);
    color: rgb(var(--color-heading));
    margin-left: 0;
  }

  @media (min-width: 992px) {
    .featured-posts .article-pin-card .text-wrap {
      position: relative;
      width: 60%;
      padding-right: 3rem;
      padding-left: 0;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .featured-posts .article-pin-card {
      display: flex;
      column-gap: 2rem;
      width: 100%;
      height: 100%;
      justify-content: space-between;
    }

    .featured-posts .image-wrap {
      width: 40%;
    }
  }

  @media (min-width: 992px) and (max-width: 1320px) {
    .featured-posts .article-pin-card .text-wrap {
      padding-right: 3rem;
      padding-left: 1rem;
    }
  }

  @media (min-width: 1321px) {
    .featured-posts .article-pin-card .text-wrap {
      padding-right: 6rem;
      padding-left: 7rem;
    }
  }

  .featured-posts .article-pin-card h2 {
    margin-bottom: clamp(2rem, 3.8vh, 2.8rem);
    color: rgb(var(--color-heading));
  }

  .featured-posts .article-pin-card .article-excerpt {
    margin-bottom: clamp(1rem, 2vh, 1.8rem);
    color: rgb(var(--color-text));
  }

  /* Hover underline buttons */
  .featured-posts .btn-wrapper,
  .featured-posts .end-link {
    width: fit-content;
  }

  .featured-posts .btn--animation.hover-underline {
    position: relative;
    display: inline-flex;
    width: fit-content;
    color: rgb(var(--color-link));
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .featured-posts .btn--animation.hover-underline::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -8px;
    width: 100%;
    height: 1px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.35s ease, opacity 0.35s ease;
    opacity: 0;
  }

  .featured-posts .btn-wrapper:hover .btn--animation.hover-underline,
  .featured-posts .end-link:hover .btn--animation.hover-underline,
  .featured-posts .text-item:hover .btn--animation.hover-underline {
    color: rgb(var(--color-link-hover));
  }

  .featured-posts .btn-wrapper:hover .btn--animation.hover-underline::after,
  .featured-posts .end-link:hover .btn--animation.hover-underline::after,
  .featured-posts .text-item:hover .btn--animation.hover-underline::after {
    transform: scaleX(1);
    opacity: 1;
  }

  /* Counter */
  .featured-posts .featured-post-count {
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
  }

  .featured-posts .counter-item {
    background: none;
    border: none;
    cursor: pointer;
    opacity: 0.4;
    font-size: 1.6rem;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .featured-posts .counter-item.active-counter {
    opacity: 1;
    font-weight: 700;
    transform: translateX(-2px);
  }

  .featured-posts .end-link {
    margin-top: clamp(3rem, 6vh, 5.5rem);
    overflow: visible;
    padding-bottom: 20px;
  }

  .featured-posts .end-link .btn--animation {
    font-size: calc(var(--btn-animation-font-size) * 1.5);
  }

  @media (max-width: 991px) {
    .featured-posts.section-x-padding {
      padding-left: 0;
      padding-right: 0;
    }

    .featured-posts .featured-post-count {
      top: 40%;
    }

    .featured-posts .featured-post-count .counter-item {
      color: #fff;
    }

    .featured-posts h1 {
      padding-top: 1rem;
    }

    .featured-posts .cropped-image--square {
      padding-bottom: 80%;
    }

    .featured-posts .article-track {
      height: clamp(26rem, 45vh, 55rem);
    }

    .featured-posts .end-link {
      margin-top: clamp(2rem, 3vh, 3.5rem);
    }

    .featured-posts .text-wrap {
      padding-top: 1rem;
      padding-left: 1.2rem;
      padding-right: 1.2rem;
    }
  }
{% endstylesheet %}

{%- assign blog_object = blogs[section.settings.blog] -%}

{%- liquid
  assign classes = 'featured-posts section-x-padding'
  assign classes = classes | append: ' section-' | append: section.id | append: '-padding'
  assign classes = classes | append: ' ' | append: section.settings.color_control
  assign classes = classes | append: ' m-color-' | append: section.settings.text_color_scheme
  assign classes = classes | append: ' ' | append: section.settings.custom_class | default: ''
  assign wrapper_title_size = '' | append: section.settings.wrapper_title_font_size | default: ''
  assign post_title_font = '' | append: section.settings.post_title_font | default: ''
-%}

{% if blog_object.articles.size > 0 %}
  <section class="{{ classes }}" data-featured-articles>
    <h1 class="container sidebar-space {{ wrapper_title_size }}">
      {{ section.settings.wrapper_title }}
    </h1>

    <div class="articles-wrapper sidebar-space">
      <div class="article-track">
        {% for article in blog_object.articles limit: 2 %}
          <article
            class="article-slide {% if forloop.first %}is-active{% endif %}"
            data-slide="{{ forloop.index0 }}"
          >
            <div class="article-pin-card">
              <div class="image-wrap">
                <a href="{{ article.url }}" class="image-item">
                  <div class="cropped-image-wrapper cropped-image--square">
                    {% if article.image %}
                      <img
                        srcset="
                          {{ article.image | image_url: width: 900 }} 1x,
                          {{ article.image | image_url: width: 900, scale: 2 }} 2x
                        "
                        src="{{ article.image | image_url: width: 900 }}"
                        alt="{{ article.image.alt | escape | default: article.title }}"
                        loading="lazy"
                        width="{{ article.image.width }}"
                        height="{{ article.image.height }}"
                      >
                    {% endif %}
                  </div>
                </a>
              </div>

              <div class="text-wrap">
                <div class="featured-post-count">
                  {% for article in blog_object.articles limit: 2 %}
                    <button
                      class="counter-item {% if forloop.first %}active-counter{% endif %}"
                      data-index="{{ forloop.index0 }}"
                    >
                      {{ forloop.index | prepend: '0' }}
                    </button>
                  {% endfor %}
                </div>

                <a href="{{ article.url }}" class="text-item">
                  <h2 class="article-title {{ post_title_font }}">{{ article.title }}</h2>

                  <span class="hide-tablet hide-mobile hide-tablet-landscape">
                    {% if article.excerpt != blank %}
                      <p class="article-excerpt">
                        {{ article.excerpt | strip_html | truncate: 200 }}
                      </p>
                    {% else %}
                      <p class="article-excerpt">
                        {{ article.content | strip_html | truncate: 200 }}
                      </p>
                    {% endif %}
                  </span>

                  <span class="btn-wrapper">
                    <p class="btn--animation hover-underline">Explore</p>
                  </span>
                </a>
              </div>
            </div>
          </article>
        {% endfor %}
      </div>
    </div>

    <div class="container sidebar-space end-link">
      <a class="btn--animation hover-underline" href="{{ section.settings.blog.url }}">All Features</a>
    </div>
  </section>
{% endif %}

{% javascript %}
  document.addEventListener('DOMContentLoaded', initPinnedArticles);
  document.addEventListener('shopify:section:load', initPinnedArticles);

  function initPinnedArticles() {
    if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;

    gsap.registerPlugin(ScrollTrigger);

    document.querySelectorAll('[data-featured-articles]').forEach(section => {
      if (section.dataset.init) return;
      section.dataset.init = 'true';

      const slides = section.querySelectorAll('.article-slide');
      const counterGroups = section.querySelectorAll('.featured-post-count');
      const slidesCount = slides.length;
      const SCROLL_STEP = 500;
      let activeIndex = 0;

      function animateSlideIn(slide) {
        const image = slide.querySelector('.image-wrap');
        const title = slide.querySelector('.article-title');
        const excerpt = slide.querySelector('.article-excerpt');
        const button = slide.querySelector('.btn-wrapper');
        const counter = slide.querySelector('.featured-post-count');

        const parts = [image, title, excerpt, button, counter].filter(Boolean);

        gsap.killTweensOf(parts);

        gsap.set(parts, { clearProps: 'all' });
        gsap.set(image, { opacity: 0, x: 40, scale: 0.96 });
        gsap.set([title, excerpt, button], { opacity: 0, y: 24 });
        gsap.set(counter, { opacity: 0, x: 16 });

        gsap.timeline()
          .to(image, {
            opacity: 1,
            x: 0,
            scale: 1,
            duration: 0.8,
            ease: 'power3.out'
          })
          .to([title, excerpt, button], {
            opacity: 1,
            y: 0,
            duration: 0.6,
            ease: 'power3.out',
            stagger: 0.12
          }, '-=0.45')
          .to(counter, {
            opacity: 1,
            x: 0,
            duration: 0.45,
            ease: 'power2.out'
          }, '-=0.45');
      }

      function animateSlideOut(slide) {
        const image = slide.querySelector('.image-wrap');
        const title = slide.querySelector('.article-title');
        const excerpt = slide.querySelector('.article-excerpt');
        const button = slide.querySelector('.btn-wrapper');
        const counter = slide.querySelector('.featured-post-count');

        const parts = [image, title, excerpt, button, counter].filter(Boolean);

        gsap.killTweensOf(parts);

        gsap.to(parts, {
          opacity: 0,
          y: 10,
          duration: 0.2,
          ease: 'power1.out',
          overwrite: true
        });
      }

      function activateSlide(index, forceAnimate = false) {
        if (index === activeIndex && !forceAnimate) return;

        slides.forEach((slide, i) => {
          const isActive = i === index;

          if (slide.classList.contains('is-active') && !isActive) {
            animateSlideOut(slide);
          }

          slide.classList.toggle('is-active', isActive);
        });

        counterGroups.forEach(group => {
          const buttons = group.querySelectorAll('.counter-item');
          buttons.forEach((btn, i) => {
            btn.classList.toggle('active-counter', i === index);
          });
        });

        const activeSlide = slides[index];
        if (activeSlide) {
          animateSlideIn(activeSlide);
        }

        activeIndex = index;
      }

      counterGroups.forEach(group => {
        group.querySelectorAll('.counter-item').forEach(btn => {
          btn.addEventListener('click', () => {
            activateSlide(+btn.dataset.index, true);
          });
        });
      });

      ScrollTrigger.create({
        trigger: section,
        start: 'top top',
        end: `+=${slidesCount * SCROLL_STEP}`,
        pin: true,
        scrub: true,
        onEnter: () => {
          activateSlide(0, true);
        },
        onUpdate(self) {
          const index = Math.round(self.progress * (slidesCount - 1));
          if (index !== activeIndex) {
            activateSlide(index);
          }
        }
      });

      activateSlide(0, true);
    });
  }
{% endjavascript %}

{% schema %}
{
  "name": "Featured Articles",
  "settings": [
    {
      "type": "color_scheme",
      "id": "text_color_scheme",
      "label": "Text color scheme"
    },
    {
      "type": "text",
      "id": "wrapper_title",
      "label": "Section title",
      "default": "Featured Articles"
    },
    {
      "type": "select",
      "id": "wrapper_title_font_size",
      "label": "Font Size",
      "options": [
        { "value": "h1", "label": "h1" },
        { "value": "h2", "label": "h2" },
        { "value": "h3", "label": "h3" },
        { "value": "h4", "label": "h4" }
      ],
      "default": "h2"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Select blog"
    },
    {
      "type": "select",
      "id": "post_title_font",
      "label": "Post title font",
      "options": [
        { "value": "h2", "label": "h2" },
        { "value": "h3", "label": "h3" },
        { "value": "h4", "label": "h4" },
        { "value": "h5", "label": "h5" }
      ],
      "default": "h2"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 0
    },
    {
      "type": "header",
      "content": "Dynamic Option"
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom class"
    },
    {
      "type": "select",
      "id": "color_control",
      "label": "Color Control",
      "options": [
        { "value": "section-dark", "label": "Dark" },
        { "value": "section-light", "label": "Light" }
      ],
      "default": "section-light"
    }
  ],
  "presets": [
    {
      "name": "Featured Articles",
      "category": "Blog"
    }
  ]
}
{% endschema %}