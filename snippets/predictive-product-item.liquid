{%- comment -%}
  Predictive product Item
  Used for search drawer, nav, etc.
  using: {% render 'predictive-product-item', product: product, enable_search_data: true %}
{%- endcomment -%}

{% assign enable_search_data = enable_search_data | default: false %}

{% if enable_search_data %}
  {% assign collections_titles = product.collections | map: 'title' | join: ',' | downcase %}
  {% assign tags = product.tags | join: ',' | downcase %}
  {% assign title = product.title | downcase %}
{% endif %}

{% liquid
  assign enable_price_display_mode = settings.enable_product_price_display_mode
  assign tax_display_mode = settings.product_price_tax_display_mode | default: 'single_price'
  assign manual_tax_rate = settings.product_manual_tax_rate | plus: 0
  assign tax_multiplier = manual_tax_rate | divided_by: 100.0 | plus: 1.0

  assign display_main_price = product.price
  assign display_tax_exclusive_price = blank

  if manual_tax_rate > 0
    if cart.taxes_included
      assign display_tax_exclusive_price = product.price | divided_by: tax_multiplier
    else
      assign display_tax_exclusive_price = product.price
    endif
  endif
%}

<div
  class="search-product-item"
  {% if enable_search_data %}
    data-title="{{ title }}"
    data-tags="{{ tags }}"
    data-collection="{{ collections_titles }}"
  {% endif %}
>
  <a href="{{ product.url }}" class="product-card">
    <div class="product-card__image cropped-image-wrapper {{ settings.aspect_ratio }}">
      {% if product.featured_image %}
        {{ product.featured_image | image_url: width: 300 | image_tag: loading: 'lazy', alt: product.title }}
      {% else %}
        {%- render 'theme-icon', icon: 'default-image' -%}
      {% endif %}
    </div>

    <div class="product-card__info">
      <h5>{{ product.title }}</h5>

      <div class="predictive-product-price-wrap">
        {% if enable_price_display_mode %}
          {% case tax_display_mode %}
            {% when 'single_price' %}
              <span class="price">
                {{ display_main_price | money }}
              </span>

            {% when 'single_price_with_tax_label' %}
              <div class="predictive-product-price-group">
                <span class="price">
                  {{ display_main_price | money }}
                </span>
                {% if cart.taxes_included %}
                  <span class="predictive-product-tax-label">Incl. tax</span>
                {% else %}
                  <span class="predictive-product-tax-label">Excl. tax</span>
                {% endif %}
              </div>

            {% when 'single_price_without_tax' %}
              <span class="price">
                {% if display_tax_exclusive_price != blank %}
                  {{ display_tax_exclusive_price | money }}
                {% else %}
                  {{ display_main_price | money }}
                {% endif %}
              </span>

            {% when 'price_with_and_without_tax' %}
              <div class="predictive-product-price-group">
                <span class="price">
                  {{ display_main_price | money }}
                </span>
                <span class="predictive-product-tax-label">Incl. tax</span>

                {% if display_tax_exclusive_price != blank %}
                  <span class="price predictive-product-price-secondary">
                    {{ display_tax_exclusive_price | money }}
                  </span>
                  <span class="predictive-product-tax-label">Excl. tax</span>
                {% endif %}
              </div>
          {% endcase %}
        {% else %}
          <span class="price">
            {{ product.price | money }}
          </span>
        {% endif %}
      </div>
    </div>
  </a>
</div>

{% stylesheet %}
  .predictive-product-price-wrap {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.1rem;
    line-height: 1.15;
  }

  .predictive-product-price-group {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.1rem;
    line-height: 1.15;
  }

  .predictive-product-tax-label {
    font-size: 0.72em;
    opacity: 0.7;
    color: rgb(var(--color-subtext));
  }

  .predictive-product-price-secondary {
    opacity: 0.92;
  }
{% endstylesheet %}



