<div id="js-notify-me" class="notify-me hide m-color-{{ settings.notify_me_color }}">
  <div class="inner-notify-me">

    {% form 'customer', class: 'footer__form' %}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <input type="email" name="contact[email]" placeholder="Email address" required>

      {% if block.settings.text != blank %}
        <div class="newsletter__text">{{ block.settings.text }}</div>
      {% endif %}

      <button type="submit" class="newsletter__submit">
        Subscribe
      </button>
    {% endform %}
{% comment %} Test Data {% endcomment %}
  </div>
<div id="notify-me-overlay"></div>
</div>
{% stylesheet %}
.notify-me .inner-notify-me{
    position: fixed;
    bottom: 50%;
    right: 50%; 
    padding: 15px 25px;
    z-index: 1000;
    transform: translateX(50%);
    background: rgb(var(--color-background));
}
#notify-me-overlay{
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: var(--color-overlay);
    opacity: var(--color-overlay-opacity);
    z-index: 999;
}
{% endstylesheet %} 
