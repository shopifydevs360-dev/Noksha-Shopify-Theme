
<div id="js-bag-drawer" class="shopify-section-bag noksha-drawer add-to-cart-action m-color-{{ section.settings.sidebar_color_scheme }}" data-open-section="bag-drawer">
    <div class="inner-section drawer-space">
        {% render 'cart-template' %}
    </div>
</div>

{% stylesheet %}
  .shopify-section-bag {
  max-width: 70rem;
  background: #f0eee8;
}
.shopify-section-bag .cart-list-items {
    overflow-y: scroll;
    height: 34vh;
    padding-right: 0.5rem;
}
@media (min-width: 991px){
  .shopify-section-bag .cart-list-items {
      height: 68vh;
  }
}

{% endstylesheet %}