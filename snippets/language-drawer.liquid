<div
  id="js-language-drawer"
  class="shopify-section-language noksha-drawer m-color-{{ section.settings.sidebar_color_scheme }}"
  data-open-section="language-drawer"
>
  <div class="inner-section drawer-space">
    <div class="container">
      <h4 class="title">Your language</h4>
      <div class="language-drawer__items" data-language-drawer-items></div>
      <div class="language-drawer__empty hide" data-language-drawer-empty>
        <p>Your language is empty.</p>
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
    .shopify-section-language{
      max-width: 45rem;
      background: #f0eee8;
  }
    .shopify-section-language .container{
      overflow-y: auto;
      -webkit-overflow-scrolling: touch;
      max-height: 80vh;
      padding: 0 1rem;
      min-width: fit-content;
      padding-bottom: 4rem;
   }

     .shopify-section-language .title {
      display: block;
      font-size: 1em;
      text-transform: uppercase;
      font-weight: 600;
      letter-spacing: 2px;
      margin-bottom: 2rem;
  }

{% endstylesheet %}
