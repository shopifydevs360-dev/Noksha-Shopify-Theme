<localization-form class="sidebar-localization">
  {%- form 'localization', id: 'SidebarLanguageForm', class: 'localization-form' -%}
    <div class="sidebar-localization__inner">
      <label class="sidebar-localization__label" for="SidebarLanguageToggle">
        Select Language
      </label>

      <div class="disclosure disclosure--language js-language-disclosure">
        <button
          id="SidebarLanguageToggle"
          type="button"
          class="disclosure__button js-language-toggle"
          aria-expanded="false"
          aria-controls="SidebarLanguageList"
        >
          <span class="language-selected-text">
            {{ localization.language.endonym_name | capitalize }}
          </span>

          <span class="disclosure__caret" aria-hidden="true">
            {{ 'icon-caret.svg' | inline_asset_content }}
          </span>
        </button>

        <div class="disclosure__list-wrapper js-language-list">
          <ul id="SidebarLanguageList" role="list" class="disclosure__list list-unstyled">
            {%- for language in localization.available_languages -%}
              <li class="disclosure__item">
                <button
                  type="submit"
                  name="locale_code"
                  class="disclosure__link"
                  value="{{ language.iso_code }}"
                  lang="{{ language.iso_code }}"
                  {% if language.iso_code == localization.language.iso_code %}
                    aria-current="true"
                  {% endif %}
                >
                  <span class="checkmark-icon-wrapper" aria-hidden="true">
                    {% if language.iso_code == localization.language.iso_code %}
                      {{ 'icon-checkmark.svg' | inline_asset_content }}
                    {% endif %}
                  </span>

                  <span class="language-name">
                    {{ language.endonym_name | capitalize }}
                  </span>
                </button>
              </li>
            {%- endfor -%}
          </ul>
        </div>
      </div>
    </div>
  {%- endform -%}
</localization-form>

{% stylesheet %}
  .sidebar-localization {
    width: 100%;
  }

  .sidebar-localization__inner {
    width: 100%;
  }

  .sidebar-localization__label {
    display: block;
    margin: 0 0 0.6rem;
    font-size: 0.8rem;
    line-height: 1.4;
    letter-spacing: 0.08em;
    color: rgb(var(--color-subtext));
  }

  .sidebar-localization .disclosure {
    position: relative;
    width: 100%;
  }

  .sidebar-localization .disclosure__button {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.85rem 0;
    border: 0;
    border-bottom: 1px solid rgb(var(--color-border));
    background: transparent;
    color: rgb(var(--color-heading));
    text-align: left;
    cursor: pointer;
    transition: border-color 0.25s ease, opacity 0.25s ease;
  }

  .sidebar-localization .disclosure__button:hover {
    border-color: rgb(var(--color-heading));
  }

  .sidebar-localization .disclosure__button:focus-visible {
    outline: none;
    border-color: rgb(var(--color-heading));
  }

  .sidebar-localization .language-selected-text {
    display: inline-block;
    font-size: 1rem;
    line-height: 1.3;
    color: rgb(var(--color-heading));
  }

  .sidebar-localization .disclosure__caret {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    width: 0.9rem;
    height: 0.9rem;
    transition: transform 0.3s ease;
  }

  .sidebar-localization .disclosure__caret svg {
    width: 100%;
    height: 100%;
  }

  .sidebar-localization .disclosure__list-wrapper {
    display: none;
    margin-top: 0.7rem;
    opacity: 0;
    transform: translateY(5px);
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  .sidebar-localization .disclosure.is-open .disclosure__list-wrapper {
    display: block;
    opacity: 1;
    transform: translateY(0);
  }

  .sidebar-localization .disclosure.is-open .disclosure__caret {
    transform: rotate(180deg);
  }

  .sidebar-localization .disclosure__list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .sidebar-localization .disclosure__item + .disclosure__item {
    margin-top: 0.15rem;
  }

  .sidebar-localization .disclosure__link {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.5rem 0;
    border: 0;
    background: transparent;
    text-align: left;
    cursor: pointer;
    color: rgb(var(--color-text));
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .sidebar-localization .disclosure__link:hover {
    opacity: 0.65;
    transform: translateX(2px);
  }

  .sidebar-localization .disclosure__link[aria-current="true"] {
    font-weight: 600;
    color: rgb(var(--color-heading));
  }

  .sidebar-localization .checkmark-icon-wrapper {
    width: 1rem;
    min-width: 1rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .sidebar-localization .checkmark-icon-wrapper svg {
    width: 0.85rem;
    height: 0.85rem;
  }

  .sidebar-localization .language-name {
    display: inline-block;
    line-height: 1.4;
  }

  body.rtl .sidebar-localization .disclosure__button,
  body.rtl .sidebar-localization .disclosure__link {
    text-align: right;
  }

  body.rtl .sidebar-localization .disclosure__link:hover {
    transform: translateX(-2px);
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    function initSidebarLanguageSelector(scope) {
      var container = scope || document;
      var languageDisclosures = container.querySelectorAll('.js-language-disclosure');

      if (!languageDisclosures.length) return;

      languageDisclosures.forEach(function (disclosure) {
        if (disclosure.dataset.initialized === 'true') return;
        disclosure.dataset.initialized = 'true';

        var toggleBtn = disclosure.querySelector('.js-language-toggle');

        if (!toggleBtn) return;

        toggleBtn.addEventListener('click', function (event) {
          event.preventDefault();

          var isOpen = disclosure.classList.contains('is-open');

          document.querySelectorAll('.js-language-disclosure.is-open').forEach(function (item) {
            if (item !== disclosure) {
              item.classList.remove('is-open');

              var itemBtn = item.querySelector('.js-language-toggle');
              if (itemBtn) {
                itemBtn.setAttribute('aria-expanded', 'false');
              }
            }
          });

          disclosure.classList.toggle('is-open', !isOpen);
          toggleBtn.setAttribute('aria-expanded', String(!isOpen));
        });
      });
    }

    document.addEventListener('DOMContentLoaded', function () {
      initSidebarLanguageSelector(document);
    });

    document.addEventListener('shopify:section:load', function (event) {
      initSidebarLanguageSelector(event.target);
    });

    document.addEventListener('click', function (event) {
      document.querySelectorAll('.js-language-disclosure.is-open').forEach(function (disclosure) {
        if (!disclosure.contains(event.target)) {
          disclosure.classList.remove('is-open');

          var toggleBtn = disclosure.querySelector('.js-language-toggle');
          if (toggleBtn) {
            toggleBtn.setAttribute('aria-expanded', 'false');
          }
        }
      });
    });
  })();
{% endjavascript %}