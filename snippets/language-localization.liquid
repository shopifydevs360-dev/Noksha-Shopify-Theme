<localization-form class="header-localization">
  {%- form 'localization', id: 'HeaderLanguageForm', class: 'localization-form' -%}
    <div class="disclosure disclosure--language">
      <button
        type="button"
        class="disclosure__button localization-form__select localization-selector link link--text caption-large"
        aria-expanded="false"
        aria-controls="LanguageList"
        aria-describedby="HeaderLanguageLabel"
      >
        <span class="language-selected-text">{{ localization.language.endonym_name | capitalize }}</span>
        <span class="disclosure__caret">
          {{ 'icon-caret.svg' | inline_asset_content }}
        </span>
      </button>

      <!-- ✅ Use CSS visibility, not 'hidden' attribute -->
      <div class="disclosure__list-wrapper language-selector" style="display: none;">
        <ul id="LanguageList" role="list" class="disclosure__list list-unstyled">
          {%- for language in localization.available_languages -%}
            <li class="disclosure__item">
              <button
                type="submit"
                name="locale_code"
                class="disclosure__link link--text caption-large"
                value="{{ language.iso_code }}"
                lang="{{ language.iso_code }}"
                {% if language.iso_code == localization.language.iso_code %}
                  aria-current="true"
                {% endif %}
              >
                <span class="checkmark-icon-wrapper">
                  {% if language.iso_code == localization.language.iso_code %}
                    {{ 'icon-checkmark.svg' | inline_asset_content }}
                  {% endif %}
                </span>
                <span class="language-name">
                  {{ language.endonym_name | capitalize }}
                </span>
              </button>
            </li>
          {%- endfor -%}
        </ul>
      </div>
    </div>
  {%- endform -%}
</localization-form>
<script>
  const toggleBtn = document.querySelector('.disclosure__button');
const listWrapper = document.querySelector('.language-selector');

toggleBtn.addEventListener('click', () => {
  const isOpen = listWrapper.style.display === 'block';
  listWrapper.style.display = isOpen ? 'none' : 'block';
});

</script>
{% if request.locale.iso_code == 'ar' %}
<style>
  .disclosure__list-wrapper {
    left: unset !important;
    right: 0;
}
</style>
{% endif %}