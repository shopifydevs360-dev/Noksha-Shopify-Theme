<localization-form class="header-localization">
  {%- form 'localization', id: 'HeaderLanguageForm', class: 'localization-form' -%}
    <div class="disclosure disclosure--language" data-localization-disclosure>
      <button
        type="button"
        class="disclosure__button localization-form__select localization-selector"
        aria-expanded="false"
        aria-controls="LanguageList"
        data-localization-toggle
      >
        <span class="language-selected-text">
          {{ localization.language.endonym_name | capitalize }}
        </span>

        <span class="disclosure__caret" aria-hidden="true">
          {{ 'icon-caret.svg' | inline_asset_content }}
        </span>
      </button>

      <div
        id="LanguageList"
        class="disclosure__list-wrapper language-selector"
        hidden
        data-localization-panel
      >
        <ul role="list" class="disclosure__list list-unstyled">
          {%- for language in localization.available_languages -%}
            <li class="disclosure__item">
              <button
                type="submit"
                name="locale_code"
                class="disclosure__link"
                value="{{ language.iso_code }}"
                lang="{{ language.iso_code }}"
                {% if language.iso_code == localization.language.iso_code %}
                  aria-current="true"
                {% endif %}
              >
                <span class="checkmark-icon-wrapper" aria-hidden="true">
                  {% if language.iso_code == localization.language.iso_code %}
                    {{ 'icon-checkmark.svg' | inline_asset_content }}
                  {% endif %}
                </span>

                <span class="language-name">
                  {{ language.endonym_name | capitalize }}
                </span>
              </button>
            </li>
          {%- endfor -%}
        </ul>
      </div>
    </div>
  {%- endform -%}
</localization-form>

<style>
  .header-localization {
    position: relative;
    display: inline-block;
  }

  .header-localization .disclosure--language {
    position: relative;
  }

  .header-localization .disclosure__button {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.7rem;
    min-width: 9.5rem;
    padding: 0.8rem 1rem;
    border: 1px solid rgba(var(--color-border), 0.8);
    background: rgb(var(--color-background));
    color: rgb(var(--color-heading));
    font-size: 0.95rem;
    line-height: 1;
    cursor: pointer;
    transition: all 0.25s ease;
  }

  .header-localization .disclosure__button:hover {
    border-color: rgba(var(--color-heading), 0.35);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
  }

  .header-localization .language-selected-text {
    display: block;
    text-align: left;
    font-size: 0.95rem;
    color: rgb(var(--color-heading));
  }

  .header-localization .disclosure__caret {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 0.9rem;
    height: 0.9rem;
    transition: transform 0.25s ease;
    flex-shrink: 0;
  }

  .header-localization .disclosure__button[aria-expanded="true"] .disclosure__caret {
    transform: rotate(180deg);
  }

  .header-localization .disclosure__caret svg {
    width: 100%;
    height: 100%;
  }

  .header-localization .disclosure__list-wrapper {
    position: absolute;
    top: calc(100% + 0.7rem);
    left: 0;
    min-width: 100%;
    width: 14rem;
    padding: 0.45rem;
    background: rgb(var(--color-background));
    border: 1px solid rgba(var(--color-border), 0.9);
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.08);
    z-index: 50;
    transform: translateY(6px);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.22s ease, transform 0.22s ease, visibility 0.22s ease;
  }

  .header-localization .disclosure__list-wrapper.is-open {
    transform: translateY(0);
    opacity: 1;
    visibility: visible;
  }

  .header-localization .disclosure__list-wrapper[hidden] {
    display: block;
  }

  .header-localization .disclosure__list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .header-localization .disclosure__item + .disclosure__item {
    margin-top: 0.2rem;
  }

  .header-localization .disclosure__link {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 0.8rem 0.9rem;
    border: 0;
    background: transparent;
    color: rgb(var(--color-heading));
    text-align: left;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .header-localization .disclosure__link:hover {
    background: rgba(var(--color-heading), 0.05);
  }

  .header-localization .disclosure__link[aria-current="true"] {
    background: rgba(var(--color-heading), 0.06);
    font-weight: 500;
  }

  .header-localization .checkmark-icon-wrapper {
    width: 1rem;
    height: 1rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .header-localization .checkmark-icon-wrapper svg {
    width: 100%;
    height: 100%;
  }

  .header-localization .language-name {
    flex: 1;
    line-height: 1.3;
    font-size: 0.95rem;
  }

  .rtl .header-localization .disclosure__list-wrapper,
  [dir="rtl"] .header-localization .disclosure__list-wrapper {
    left: auto;
    right: 0;
  }

  .rtl .header-localization .language-selected-text,
  .rtl .header-localization .disclosure__link,
  [dir="rtl"] .header-localization .language-selected-text,
  [dir="rtl"] .header-localization .disclosure__link {
    text-align: right;
  }

  @media (max-width: 767px) {
    .header-localization .disclosure__button {
      min-width: 8.5rem;
      padding: 0.75rem 0.9rem;
      font-size: 0.9rem;
    }

    .header-localization .disclosure__list-wrapper {
      width: 12rem;
    }

    .header-localization .disclosure__link {
      padding: 0.75rem 0.8rem;
    }
  }
</style>

<script>
  (function () {
    function initLocalizationDisclosure(scope) {
      var container = scope || document;
      var disclosures = container.querySelectorAll('[data-localization-disclosure]');

      disclosures.forEach(function(disclosure) {
        if (disclosure.dataset.initialized === 'true') return;
        disclosure.dataset.initialized = 'true';

        var toggle = disclosure.querySelector('[data-localization-toggle]');
        var panel = disclosure.querySelector('[data-localization-panel]');
        if (!toggle || !panel) return;

        function openPanel() {
          panel.hidden = false;

          requestAnimationFrame(function() {
            panel.classList.add('is-open');
          });

          toggle.setAttribute('aria-expanded', 'true');
        }

        function closePanel() {
          panel.classList.remove('is-open');
          toggle.setAttribute('aria-expanded', 'false');

          setTimeout(function() {
            if (toggle.getAttribute('aria-expanded') === 'false') {
              panel.hidden = true;
            }
          }, 220);
        }

        function togglePanel() {
          var isOpen = toggle.getAttribute('aria-expanded') === 'true';

          document.querySelectorAll('[data-localization-disclosure]').forEach(function(otherDisclosure) {
            var otherToggle = otherDisclosure.querySelector('[data-localization-toggle]');
            var otherPanel = otherDisclosure.querySelector('[data-localization-panel]');

            if (otherDisclosure !== disclosure && otherToggle && otherPanel) {
              otherPanel.classList.remove('is-open');
              otherToggle.setAttribute('aria-expanded', 'false');
              setTimeout(function() {
                if (otherToggle.getAttribute('aria-expanded') === 'false') {
                  otherPanel.hidden = true;
                }
              }, 220);
            }
          });

          if (isOpen) {
            closePanel();
          } else {
            openPanel();
          }
        }

        toggle.addEventListener('click', function(e) {
          e.preventDefault();
          togglePanel();
        });

        document.addEventListener('click', function(e) {
          if (!disclosure.contains(e.target)) {
            closePanel();
          }
        });

        document.addEventListener('keydown', function(e) {
          if (e.key === 'Escape') {
            closePanel();
          }
        });
      });
    }

    document.addEventListener('DOMContentLoaded', function() {
      initLocalizationDisclosure(document);
    });

    document.addEventListener('shopify:section:load', function(event) {
      initLocalizationDisclosure(event.target);
    });
  })();
</script>