<localization-form class="sidebar-localization">
  {%- form 'localization', id: 'SidebarLanguageForm', class: 'localization-form' -%}
    <div class="disclosure disclosure--language js-language-disclosure">
      <button
        type="button"
        class="disclosure__button localization-form__select localization-selector link link--text caption-large js-language-toggle"
        aria-expanded="false"
        aria-controls="SidebarLanguageList"
      >
        <span class="language-selected-text">
          {{ localization.language.endonym_name | capitalize }}
        </span>
        <span class="disclosure__caret">
          {{ 'icon-caret.svg' | inline_asset_content }}
        </span>
      </button>

      <div class="disclosure__list-wrapper language-selector js-language-list">
        <ul id="SidebarLanguageList" role="list" class="disclosure__list list-unstyled">
          {%- for language in localization.available_languages -%}
            <li class="disclosure__item">
              <button
                type="submit"
                name="locale_code"
                class="disclosure__link link--text caption-large"
                value="{{ language.iso_code }}"
                lang="{{ language.iso_code }}"
                {% if language.iso_code == localization.language.iso_code %}
                  aria-current="true"
                {% endif %}
              >
                <span class="checkmark-icon-wrapper">
                  {% if language.iso_code == localization.language.iso_code %}
                    {{ 'icon-checkmark.svg' | inline_asset_content }}
                  {% endif %}
                </span>
                <span class="language-name">
                  {{ language.endonym_name | capitalize }}
                </span>
              </button>
            </li>
          {%- endfor -%}
        </ul>
      </div>
    </div>
  {%- endform -%}
</localization-form>
{% stylesheet %}
  .sidebar-localization {
  width: 100%;
}

.sidebar-localization .disclosure {
  position: relative;
  width: 100%;
}

.sidebar-localization .disclosure__button {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  text-align: left;
  padding: 0.8rem 0;
  color: rgb(var(--color-heading));
}

.sidebar-localization .language-selected-text {
  display: inline-block;
}

.sidebar-localization .disclosure__caret {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.3s ease;
}

.sidebar-localization .disclosure__list-wrapper {
  display: none;
  margin-top: 0.75rem;
  padding: 0.75rem 0;
  border-top: 1px solid rgb(var(--color-border));
}

.sidebar-localization .disclosure.is-open .disclosure__list-wrapper {
  display: block;
}

.sidebar-localization .disclosure.is-open .disclosure__caret {
  transform: rotate(180deg);
}

.sidebar-localization .disclosure__list {
  margin: 0;
  padding: 0;
  list-style: none;
}

.sidebar-localization .disclosure__item + .disclosure__item {
  margin-top: 0.35rem;
}

.sidebar-localization .disclosure__link {
  width: 100%;
  display: flex;
  align-items: center;
  gap: 0.8rem;
  text-align: left;
  padding: 0.5rem 0;
  color: rgb(var(--color-text));
}

.sidebar-localization .checkmark-icon-wrapper {
  width: 1rem;
  min-width: 1rem;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.sidebar-localization .language-name {
  display: inline-block;
}

body.rtl .sidebar-localization .disclosure__button,
body.rtl .sidebar-localization .disclosure__link {
  text-align: right;
}
{% endstylesheet %}
{% javascript %}
  document.addEventListener('DOMContentLoaded', () => {
  initSidebarLanguageSelector();
});

document.addEventListener('shopify:section:load', () => {
  initSidebarLanguageSelector();
});

function initSidebarLanguageSelector() {
  const languageDisclosures = document.querySelectorAll('.js-language-disclosure');

  if (!languageDisclosures.length) return;

  languageDisclosures.forEach((disclosure) => {
    if (disclosure.dataset.initialized === 'true') return;
    disclosure.dataset.initialized = 'true';

    const toggleBtn = disclosure.querySelector('.js-language-toggle');
    const listWrapper = disclosure.querySelector('.js-language-list');

    if (!toggleBtn || !listWrapper) return;

    toggleBtn.addEventListener('click', (event) => {
      event.preventDefault();

      const isOpen = disclosure.classList.contains('is-open');

      document.querySelectorAll('.js-language-disclosure.is-open').forEach((item) => {
        if (item !== disclosure) {
          item.classList.remove('is-open');
          const btn = item.querySelector('.js-language-toggle');
          if (btn) btn.setAttribute('aria-expanded', 'false');
        }
      });

      disclosure.classList.toggle('is-open', !isOpen);
      toggleBtn.setAttribute('aria-expanded', String(!isOpen));
    });
  });

  document.addEventListener('click', function (event) {
    document.querySelectorAll('.js-language-disclosure.is-open').forEach((disclosure) => {
      if (!disclosure.contains(event.target)) {
        disclosure.classList.remove('is-open');
        const btn = disclosure.querySelector('.js-language-toggle');
        if (btn) btn.setAttribute('aria-expanded', 'false');
      }
    });
  });
}
{% endjavascript %}