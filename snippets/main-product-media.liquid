{%- liquid
  if product == blank
    echo 'Product media unavailable'
    break
  endif

  assign media_count = product.media.size
  assign main_media_ratio = section.settings.main_media_ratio | default: 'cropped-image--portrait'
  assign thumb_media_ratio = section.settings.thumb_media_ratio | default: 'cropped-image--square'
  assign video_media_ratio = section.settings.video_media_ratio | default: 'cropped-image--portrait'
  assign mobile_media_ratio = section.settings.mobile_media_ratio | default: 'cropped-image--portrait'

  assign main_image_wrapper_class = 'cropped-image-wrapper '
  assign thumb_image_wrapper_class = 'cropped-image-wrapper '
  assign mobile_image_wrapper_class = 'cropped-image-wrapper '
  assign video_wrapper_class = 'cropped-video-wrapper '

  if main_media_ratio == 'adapt-image-height'
    assign main_image_wrapper_class = main_image_wrapper_class | append: 'adapt-image-height'
  else
    assign main_image_wrapper_class = main_image_wrapper_class | append: main_media_ratio
  endif

  if thumb_media_ratio == 'adapt-image-height'
    assign thumb_image_wrapper_class = thumb_image_wrapper_class | append: 'adapt-image-height'
  else
    assign thumb_image_wrapper_class = thumb_image_wrapper_class | append: thumb_media_ratio
  endif

  if mobile_media_ratio == 'adapt-image-height'
    assign mobile_image_wrapper_class = mobile_image_wrapper_class | append: 'adapt-image-height'
  else
    assign mobile_image_wrapper_class = mobile_image_wrapper_class | append: mobile_media_ratio
  endif

  if video_media_ratio == 'adapt-video-height'
    assign video_wrapper_class = video_wrapper_class | append: 'adapt-video-height'
  else
    assign video_wrapper_class = video_wrapper_class | append: video_media_ratio
  endif

  assign show_mobile_videos = section.settings.show_mobile_videos
  assign show_mobile_video_first = section.settings.show_mobile_video_first
-%}

{%- assign image_index = 0 -%}
{%- assign has_video = false -%}
{%- assign product_image_count = 0 -%}
{%- assign mobile_custom_image_count = 0 -%}
{%- assign mobile_total_items = 0 -%}

{%- for media in product.media -%}
  {%- if media.media_type contains 'video' -%}
    {%- assign has_video = true -%}
  {%- endif -%}

  {%- if media.media_type == 'image' -%}
    {%- assign product_image_count = product_image_count | plus: 1 -%}
  {%- endif -%}
{%- endfor -%}

{%- for block in section.blocks -%}
  {%- if block.type == 'mobile_image' and block.settings.image != blank -%}
    {%- assign mobile_custom_image_count = mobile_custom_image_count | plus: 1 -%}
  {%- endif -%}
{%- endfor -%}

{%- if mobile_custom_image_count > 0 -%}
  {%- assign mobile_total_items = mobile_total_items | plus: mobile_custom_image_count -%}
{%- else -%}
  {%- assign mobile_total_items = mobile_total_items | plus: product_image_count -%}
{%- endif -%}

{%- if show_mobile_videos and has_video -%}
  {%- for media in product.media -%}
    {%- if media.media_type == 'video' or media.media_type == 'external_video' -%}
      {%- assign mobile_total_items = mobile_total_items | plus: 1 -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}

<div class="product-media">
  <!--
    =====================
         DESKTOP MAIN MEDIA
    =====================
  -->
  <div class="product-media__main swiper hide-tablet hide-mobile hide-tablet-landscape" id="MainProductMedia">
    {% if product.media.size == 0 %}
      <div class="product-media is-empty">
        <div class="product-media__fallback {{ main_image_wrapper_class }}">
          <div class="product-media__fallback-inner">
            {% render 'theme-icon', icon: 'default-image' %}
          </div>
        </div>
      </div>
    {% else %}
      <div class="swiper-wrapper">
        {% assign rendered_media_ids = '' %}
        {% assign has_variant_media = false %}
        {% assign desktop_main_image_loaded = false %}

        {% for variant in product.variants %}
          {% if variant.featured_media and variant.featured_media.media_type == 'image' %}
            {% assign has_variant_media = true %}
            {% assign media_id = variant.featured_media.id | append: '' %}

            {% unless rendered_media_ids contains media_id %}
              {% assign rendered_media_ids = rendered_media_ids | append: media_id | append: ',' %}

              <div class="swiper-slide" data-media-id="{{ variant.featured_media.id }}">
                <div class="{{ main_image_wrapper_class }}">
                  {% if desktop_main_image_loaded == false %}
                    {% render 'image',
                      class: 'js-open-lightbox',
                      image: variant.featured_media,
                      width: 1600,
                      height: variant.featured_media.height,
                      crop: 'center',
                      img_alt: variant.featured_media.alt,
                      style: wrapper_style,
                      loading: 'eager',
                      fetchpriority: 'high'
                    %}
                    {% assign desktop_main_image_loaded = true %}
                  {% else %}
                    {% render 'image',
                      class: 'js-open-lightbox',
                      image: variant.featured_media,
                      width: 1600,
                      height: variant.featured_media.height,
                      crop: 'center',
                      img_alt: variant.featured_media.alt,
                      style: wrapper_style,
                      loading: 'lazy',
                      fetchpriority: 'low'
                    %}
                  {% endif %}
                  <span class="hide" data-lightbox-index="{{ image_index }}"></span>
                </div>
              </div>

              {%- assign image_index = image_index | plus: 1 -%}
            {% endunless %}
          {% endif %}
        {% endfor %}

        {% unless has_variant_media %}
          {% assign fallback_media = product.featured_media | default: product.media.first %}

          {% if fallback_media %}
            <div class="swiper-slide" data-media-id="{{ fallback_media.id }}">
              {% if fallback_media.media_type == 'image' %}
                <div class="{{ main_image_wrapper_class }}">
                  {% render 'image',
                    class: 'js-open-lightbox',
                    image: fallback_media,
                    width: 1600,
                    height: fallback_media.height,
                    crop: 'center',
                    img_alt: fallback_media.alt,
                    style: wrapper_style,
                    loading: 'eager',
                    fetchpriority: 'high'
                  %}
                  <span class="hide" data-lightbox-index="0"></span>
                </div>
              {% elsif fallback_media.media_type == 'video' %}
                <div class="product-media__video js-open-video-lightbox" data-video-lightbox-trigger>
                  <div class="{{ video_wrapper_class }}">
                    {{
                      fallback_media
                      | video_tag:
                        autoplay: false,
                        loop: false,
                        muted: true,
                        controls: false,
                        playsinline: true,
                        preload: 'metadata'
                    }}
                  </div>
                </div>
              {% elsif fallback_media.media_type == 'external_video' %}
                <div class="product-media__video js-open-video-lightbox" data-video-lightbox-trigger>
                  <div class="{{ video_wrapper_class }}">
                    {{ fallback_media | external_video_tag }}
                  </div>
                </div>
              {% else %}
                <div class="product-media__fallback {{ main_image_wrapper_class }}">
                  <div class="product-media__fallback-inner">
                    {% render 'theme-icon', icon: 'default-image' %}
                  </div>
                </div>
              {% endif %}
            </div>
          {% endif %}
        {% endunless %}
      </div>
    {% endif %}
  </div>

  <!--
    =====================
         DESKTOP VIDEO ROW
    =====================
  -->
  {% if has_video %}
    <div class="product-media__video-row hide-tablet hide-mobile hide-tablet-landscape">
      {% for media in product.media %}
        {% if media.media_type == 'video' %}
          <div class="product-media__video js-open-video-lightbox" data-video-lightbox-trigger>
            <div class="{{ video_wrapper_class }}">
              {{
                media
                | video_tag:
                  autoplay: false,
                  loop: false,
                  muted: true,
                  controls: false,
                  playsinline: true,
                  preload: 'metadata'
              }}
            </div>
          </div>
        {% elsif media.media_type == 'external_video' %}
          <div class="product-media__video js-open-video-lightbox" data-video-lightbox-trigger>
            <div class="{{ video_wrapper_class }}">
              {{ media | external_video_tag }}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  {% endif %}

  <!--
    =====================
         DESKTOP THUMBS
    =====================
  -->
  {% if product_image_count > 1 %}
    <div class="product-media__thumbs swiper hide-tablet hide-mobile hide-tablet-landscape">
      <div class="swiper-wrapper">
        {%- assign thumb_image_index = 0 -%}

        {% for media in product.media offset: 1 %}
          {% if media.media_type == 'image' %}
            <div class="swiper-slide">
              <div class="{{ thumb_image_wrapper_class }}">
                {% render 'image',
                  class: 'js-open-lightbox',
                  image: media,
                  crop: 'center',
                  width: 500,
                  height: media.height,
                  img_alt: media.alt,
                  loading: 'lazy',
                  fetchpriority: 'low'
                %}
                <span class="hide" data-lightbox-index="{{ thumb_image_index | plus: 1 }}"></span>
              </div>
            </div>
          {% endif %}
        {% endfor %}

        {% assign first_media = product.media.first %}
        {% if first_media and first_media.media_type == 'image' %}
          <div class="swiper-slide">
            <div class="{{ thumb_image_wrapper_class }}">
              {% render 'image',
                class: 'js-open-lightbox',
                image: first_media,
                crop: 'center',
                width: 500,
                height: first_media.height,
                img_alt: first_media.alt,
                loading: 'lazy',
                fetchpriority: 'low'
              %}
              <span class="hide" data-lightbox-index="0"></span>
            </div>
          </div>
        {% endif %}
      </div>

      <div class="swiper-nav-wrapper">
        <button class="swiper-button-prev" aria-label="Previous slide">
          <span class="inner-text h5">Previous</span>
        </button>

        <button class="swiper-button-next" aria-label="Next slide">
          <span class="line"></span>
          <span class="inner-text h5">Next</span>
        </button>
      </div>

      <div class="swiper-pagination"></div>
    </div>
  {% endif %}

  <!--
    =====================
         MOBILE MEDIA
    =====================
  -->
  {% if mobile_total_items > 0 %}
    <div class="product-media__mobile swiper hide-desktop hide-large-screens">
      <div class="swiper-wrapper">
        {% assign mobile_first_visual_loaded = false %}

        {% if show_mobile_videos and show_mobile_video_first %}
          {% for media in product.media %}
            {% if media.media_type == 'video' %}
              <div class="swiper-slide">
                <div class="product-media__video js-open-video-lightbox" data-video-lightbox-trigger>
                  <div class="{{ video_wrapper_class }}">
                    {{
                      media
                      | video_tag:
                        autoplay: false,
                        loop: false,
                        muted: true,
                        controls: false,
                        playsinline: true,
                        preload: 'none'
                    }}
                  </div>
                </div>
              </div>
            {% elsif media.media_type == 'external_video' %}
              <div class="swiper-slide">
                <div class="product-media__video js-open-video-lightbox" data-video-lightbox-trigger>
                  <div class="{{ video_wrapper_class }}">
                    {{ media | external_video_tag }}
                  </div>
                </div>
              </div>
            {% endif %}
          {% endfor %}
        {% endif %}

        {% if mobile_custom_image_count > 0 %}
          {% for block in section.blocks %}
            {% if block.type == 'mobile_image' and block.settings.image != blank %}
              <div class="swiper-slide" {{ block.shopify_attributes }}>
                <div class="{{ mobile_image_wrapper_class }}">
                  {% if mobile_first_visual_loaded == false %}
                    {% render 'image',
                      image: block.settings.image,
                      width: 900,
                      height: block.settings.image.height,
                      crop: 'center',
                      img_alt: block.settings.image.alt,
                      loading: 'eager',
                      fetchpriority: 'high'
                    %}
                    {% assign mobile_first_visual_loaded = true %}
                  {% else %}
                    {% render 'image',
                      image: block.settings.image,
                      width: 900,
                      height: block.settings.image.height,
                      crop: 'center',
                      img_alt: block.settings.image.alt,
                      loading: 'lazy',
                      fetchpriority: 'low'
                    %}
                  {% endif %}
                </div>
              </div>
            {% endif %}
          {% endfor %}
        {% else %}
          {% for media in product.media %}
            {% if media.media_type == 'image' %}
              <div class="swiper-slide">
                <div class="{{ mobile_image_wrapper_class }}">
                  {% if mobile_first_visual_loaded == false %}
                    {% render 'image',
                      class: 'js-open-lightbox',
                      image: media,
                      crop: 'center',
                      width: 900,
                      height: media.height,
                      img_alt: media.alt,
                      loading: 'eager',
                      fetchpriority: 'high'
                    %}
                    {% assign mobile_first_visual_loaded = true %}
                  {% else %}
                    {% render 'image',
                      class: 'js-open-lightbox',
                      image: media,
                      crop: 'center',
                      width: 900,
                      height: media.height,
                      img_alt: media.alt,
                      loading: 'lazy',
                      fetchpriority: 'low'
                    %}
                  {% endif %}
                </div>
              </div>
            {% endif %}
          {% endfor %}
        {% endif %}

        {% if show_mobile_videos and show_mobile_video_first == false %}
          {% for media in product.media %}
            {% if media.media_type == 'video' %}
              <div class="swiper-slide">
                <div class="product-media__video js-open-video-lightbox" data-video-lightbox-trigger>
                  <div class="{{ video_wrapper_class }}">
                    {{
                      media
                      | video_tag:
                        autoplay: false,
                        loop: false,
                        muted: true,
                        controls: false,
                        playsinline: true,
                        preload: 'none'
                    }}
                  </div>
                </div>
              </div>
            {% elsif media.media_type == 'external_video' %}
              <div class="swiper-slide">
                <div class="product-media__video js-open-video-lightbox" data-video-lightbox-trigger>
                  <div class="{{ video_wrapper_class }}">
                    {{ media | external_video_tag }}
                  </div>
                </div>
              </div>
            {% endif %}
          {% endfor %}
        {% endif %}
      </div>

      <div class="swiper-nav-wrapper">
        <button class="swiper-button-prev" aria-label="Previous slide">
          <span class="inner-text h5">Previous</span>
        </button>

        <button class="swiper-button-next" aria-label="Next slide">
          <span class="line"></span>
          <span class="inner-text h5">Next</span>
        </button>
      </div>

      <div class="swiper-pagination"></div>
    </div>
  {% endif %}
</div>

<!--
  =====================
       IMAGE LIGHTBOX
  =====================
-->
<div class="media-lightbox" id="mediaLightbox">
  <div class="media-lightbox__overlay"></div>

  <div class="media-lightbox__content">
    <button class="media-lightbox__close" aria-label="Close">×</button>

    <div class="swiper media-lightbox__slider">
      <div class="swiper-wrapper">
        {% for media in product.media %}
          {% if media.media_type == 'image' %}
            <div class="swiper-slide">
              {% render 'image',
                image: media,
                width: 2000,
                height: media.height,
                img_alt: media.alt,
                loading: 'lazy',
                fetchpriority: 'low'
              %}
            </div>
          {% endif %}
        {% endfor %}
      </div>

      <div class="swiper-button-prev"></div>
      <div class="swiper-button-next"></div>
      <div class="swiper-pagination"></div>
    </div>
  </div>
</div>

<!--
  =====================
       VIDEO LIGHTBOX
  =====================
-->
<div class="media-video-lightbox" id="mediaVideoLightbox">
  <div class="media-video-lightbox__overlay"></div>

  <div class="media-video-lightbox__content">
    <button class="media-video-lightbox__close" aria-label="Close">×</button>
    <div class="media-video-lightbox__body"></div>
  </div>
</div>