<div
  id="js-wishlist-drawer"
  class="shopify-section-wishlist noksha-drawer m-color-{{ section.settings.sidebar_color_scheme }}"
  data-open-section="wishlist-drawer"
>
  <div class="inner-section drawer-space">
    <div class="container">
      <h4 class="title">Your Wishlist</h4>
      <div class="wishlist-drawer__items" data-wishlist-drawer-items></div>
      <div class="wishlist-drawer__empty hide" data-wishlist-drawer-empty>
        <p>Your wishlist is empty.</p>
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
    .shopify-section-wishlist{
      max-width: 45rem;
      background: #f0eee8;
  }
    .shopify-section-wishlist .container{
      overflow-y: auto;
      -webkit-overflow-scrolling: touch;
      max-height: 80vh;
      padding: 0 1rem;
      min-width: fit-content;
      padding-bottom: 4rem;
   }

     .shopify-section-wishlist .title {
      display: block;
      font-size: 1em;
      text-transform: uppercase;
      font-weight: 600;
      letter-spacing: 2px;
      margin-bottom: 2rem;
  }

    .wishlist-drawer__items {
        display: grid;
        grid-template-columns: repeat(2,1fr);
        gap: 2rem;
        max-width: 25rem;
    }

      /* Card */
      .wishlist-drawer__card {
        display: block;
      }

      /* Image */
      .wishlist-drawer__card-image-link {
        display: block;
        margin-bottom: 8px;
        overflow: hidden;
      }

      .wishlist-drawer__card-image {
        display: block;
        width: 100%;
        height: auto;
        object-fit: cover;
      }

      /* Title */
      .wishlist-drawer__card-title {
        margin: 0 0 4px;
        font-size: 14px;
        line-height: 1.3;
        font-weight: 400;
      }

      .wishlist-drawer__card-title a {
        color: rgb(var(--color-heading));
        text-decoration: none;
      }

      /* Price */
      .wishlist-drawer__card-price {
        font-size: 14px;
        color: rgb(var(--color-price-regular));
        line-height: 1.2;
      }

      /* Empty state */
      .wishlist-drawer__empty {
        padding: 16px 0;
        font-size: 14px;
      }
.wishlist-drawer__card {
  position: relative;
  display: grid;
  grid-template-columns: 90px 1fr;
  gap: 14px;
  align-items: start;
}

.wishlist-drawer__remove {
  position: absolute;
  top: 8px;
  right: 8px;
  width: 28px;
  height: 28px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border: 0;
  background: rgba(255, 255, 255, 0.9);
  cursor: pointer;
  z-index: 2;
  line-height: 1;
}

.wishlist-drawer__remove span {
  font-size: 20px;
  line-height: 1;
}

.wishlist-drawer__card-image-placeholder {
  color: rgba(0, 0, 0, 0.35);
  background: rgba(0, 0, 0, 0.04);
}

.wishlist-drawer__placeholder-inner {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.wishlist-drawer__placeholder-icon {
  width: 42px;
  height: 42px;
}
      /* ===============================
         RESPONSIVE
      ================================ */
      @media (max-width: 767px) {
        .wishlist-drawer__items {
          grid-template-columns: 1fr;
        }
      }
{% endstylesheet %}
