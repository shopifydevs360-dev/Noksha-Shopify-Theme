{% liquid
  assign tax_display_mode = settings.product_price_tax_display_mode | default: 'single_price'
  assign manual_tax_rate = settings.product_manual_tax_rate | plus: 0
  assign tax_multiplier = manual_tax_rate | divided_by: 100.0 | plus: 1.0
  assign selected_variant_id = product.selected_or_first_available_variant.id
%}

<div class="product-block product-title-price" {{ block.shopify_attributes }}>
  <h1 class="product-title {{ block.settings.title_font_size }}">{{ product.title }}</h1>

  <div class="product-price js-variant-price">
    {% for variant in product.variants %}
      {% liquid
        assign variant_tax_exclusive_price = blank
        assign variant_compare_tax_exclusive_price = blank

        if manual_tax_rate > 0
          if cart.taxes_included
            assign variant_tax_exclusive_price = variant.price | divided_by: tax_multiplier

            if variant.compare_at_price > variant.price
              assign variant_compare_tax_exclusive_price = variant.compare_at_price | divided_by: tax_multiplier
            endif
          else
            assign variant_tax_exclusive_price = variant.price

            if variant.compare_at_price > variant.price
              assign variant_compare_tax_exclusive_price = variant.compare_at_price
            endif
          endif
        endif
      %}

      <div
        class="variant-price-item {{ block.settings.price_font_size }}{% unless variant.id == selected_variant_id %} hide{% endunless %}"
        data-variant-id="{{ variant.id }}"
      >
        {% case tax_display_mode %}
          {% when 'single_price' %}
            {% if variant.compare_at_price > variant.price %}
              <span class="price price--sale">{{ variant.price | money }}</span>
              <span class="price price--compare">{{ variant.compare_at_price | money }}</span>
            {% else %}
              <span class="price price--regular">{{ variant.price | money }}</span>
            {% endif %}

          {% when 'single_price_with_tax_label' %}
            {% if variant.compare_at_price > variant.price %}
              <span class="price price--sale">{{ variant.price | money }}</span>
              <span class="price price--compare">{{ variant.compare_at_price | money }}</span>
            {% else %}
              <span class="price price--regular">{{ variant.price | money }}</span>
            {% endif %}

            {% if cart.taxes_included %}
              <span class="product-price-tax-label">Incl. tax</span>
            {% else %}
              <span class="product-price-tax-label">Excl. tax</span>
            {% endif %}

          {% when 'single_price_without_tax' %}
            {% if variant.compare_at_price > variant.price %}
              <span class="price price--sale">
                {% if variant_tax_exclusive_price != blank %}
                  {{ variant_tax_exclusive_price | money }}
                {% else %}
                  {{ variant.price | money }}
                {% endif %}
              </span>
              <span class="price price--compare">
                {% if variant_compare_tax_exclusive_price != blank %}
                  {{ variant_compare_tax_exclusive_price | money }}
                {% else %}
                  {{ variant.compare_at_price | money }}
                {% endif %}
              </span>
            {% else %}
              <span class="price price--regular">
                {% if variant_tax_exclusive_price != blank %}
                  {{ variant_tax_exclusive_price | money }}
                {% else %}
                  {{ variant.price | money }}
                {% endif %}
              </span>
            {% endif %}

          {% when 'price_with_and_without_tax' %}
            <div class="product-page-price-group">
              {% if variant.compare_at_price > variant.price %}
                <span class="price price--sale">{{ variant.price | money }}</span>
                <span class="price price--compare">{{ variant.compare_at_price | money }}</span>
              {% else %}
                <span class="price price--regular">{{ variant.price | money }}</span>
              {% endif %}

              <span class="product-price-tax-label">Incl. tax</span>

              {% if variant_tax_exclusive_price != blank %}
                {% if variant.compare_at_price > variant.price %}
                  <span class="price price--sale-secondary">{{ variant_tax_exclusive_price | money }}</span>
                  {% if variant_compare_tax_exclusive_price != blank %}
                    <span class="price price--compare secondary-compare-price">
                      {{ variant_compare_tax_exclusive_price | money }}
                    </span>
                  {% endif %}
                {% else %}
                  <span class="price price--regular secondary-price">
                    {{ variant_tax_exclusive_price | money }}
                  </span>
                {% endif %}

                <span class="product-price-tax-label">Excl. tax</span>
              {% endif %}
            </div>
        {% endcase %}
      </div>
    {% endfor %}
  </div>
</div>

<style>
  .product-title-price .variant-price-item {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem 0.7rem;
  }

  .product-title-price .variant-price-item.hide {
    display: none !important;
  }

  .product-title-price .product-page-price-group {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.18rem;
    line-height: 1.15;
  }

  .product-title-price .product-price-tax-label {
    display: inline-block;
    font-size: 0.72em;
    opacity: 0.7;
    color: rgb(var(--color-subtext));
    line-height: 1.2;
  }

  .product-title-price .secondary-price,
  .product-title-price .price--sale-secondary,
  .product-title-price .secondary-compare-price {
    opacity: 0.92;
  }
</style>