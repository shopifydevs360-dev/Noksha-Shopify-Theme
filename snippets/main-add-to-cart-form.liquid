<div class="product-block product-form-wrapper" {{ block.shopify_attributes }}>
  {% form 'product', product, class: 'product-form' %}
    {% assign current_variant = product.selected_or_first_available_variant %}
    {% assign inv = current_variant.inventory_quantity %}
    {% assign can_continue = current_variant.available %}
    {% assign inventory_tracked = current_variant.inventory_management %}
    <!-- REQUIRED VARIANT ID (CRITICAL) -->
    <input type="hidden" name="id" value="{{ current_variant.id }}">

    <!-- VARIANTS -->
    <div class="variant-selector">
      {% render 'product-variant-picker', product: product %}
    </div>

    <div class="qty-cart-btn-wrap">
      <!-- QUANTITY -->
      {% assign quantity_selector_type = block.settings.quantity_selector_type | default: 'dropdown' %}

      {% if quantity_selector_type == 'buttons' %}
        <div class="quantity-buttons" data-quantity-wrapper>
          <button type="button" class="qty-btn qty-minus" aria-label="Decrease quantity">−</button>

          <input
            type="number"
            name="quantity"
            value="1"
            min="1"
            class="qty-input"
            aria-label="Quantity"
          >

          <button type="button" class="qty-btn qty-plus" aria-label="Increase quantity">+</button>
        </div>
      {% else %}
        <div class="quantity-dropdown" data-qty-dropdown>
          <button type="button" class="qty-toggle" data-qty-toggle>Qty 1</button>

          <ul class="qty-list">
            {% assign quantities = '1,2,3,4,5,6' | split: ',' %}
            {% for qty in quantities %}
              <li
                class="qty-item {% if forloop.first %}is-selected{% endif %}"
                data-qty="{{ qty }}"
              >
                Qty {{ qty }}
              </li>
            {% endfor %}
          </ul>

          <input type="hidden" name="quantity" value="1">
        </div>
      {% endif %}

      <!-- ADD TO CART -->
      <div class="product-actions" data-cart-behavior="{{ block.settings.cart_behavior }}">
<button
  type="submit"
  class="btn-add-to-cart"
  data-role="add-to-cart"

  data-text-add="Add to Bag"
  data-text-preorder="Pre-order"
  data-text-soldout="Out of stock"

  {% unless current_variant.available %}
    disabled
  {% endunless %}
>

{% if inventory_tracked %}
  {% if inv <= 0 and can_continue %}
    Pre-order
  {% else %}
    Add to Bag
  {% endif %}
{% else %}
  Add to Bag
{% endif %}

</button>
      </div>
    </div>

    <!-- BUY / NOTIFY -->
    <div class="quick-checkout">
      <button
        type="button"
        class="btn-buy-now {% unless current_variant.available %}hide{% endunless %}"
        data-role="buy-now"
      >
        Buy it now
      </button>

      <button
        onclick="initNotifyMe()"
        type="button"
        class="btn-notify {% if current_variant.available %}hide{% endif %}"
        data-role="notify"
      >
        Notify me when available
      </button>
    </div>
  {% endform %}
</div>
        {% if inventory_tracked %}
          {% if inv <= 0 and can_continue %}
            Pre-order
          {% else %}
            Add to Bag
          {% endif %}
        {% else %}
          Add to Bag
        {% endif %}

          {% if current_variant.available %}
            Add to cart
          {% else %}
            {% if inv <= 0 and can_continue %}
              Pre-order
            {% else %}
              Out of stock
            {% endif %}
          {% endif %}
<script type="application/json" id="ProductVariantsJson">
  {{ product.variants | json }}
</script>
<script>
  function toggleStockUI(variantId) {
  const variant = window.product?.variants?.find(v => v.id == variantId);
  if (!variant) return;

  const addToCartBtn = document.querySelector('[data-role="add-to-cart"]');
  const buyNowBtn = document.querySelector('[data-role="buy-now"]');
  const notifyBtn = document.querySelector('[data-role="notify"]');

  if (!addToCartBtn) return;

  const textAdd = addToCartBtn.dataset.textAdd;
  const textPreorder = addToCartBtn.dataset.textPreorder;
  const textSoldout = addToCartBtn.dataset.textSoldout;

  if (variant.available) {
    addToCartBtn.disabled = false;
    buyNowBtn?.classList.remove('hide');
    notifyBtn?.classList.add('hide');

    // Preorder logic
    if (variant.inventory_management && variant.inventory_quantity <= 0 && variant.inventory_policy === "continue") {
      addToCartBtn.textContent = textPreorder;
    } else {
      addToCartBtn.textContent = textAdd;
    }

  } else {
    addToCartBtn.disabled = true;
    buyNowBtn?.classList.add('hide');
    notifyBtn?.classList.remove('hide');

    addToCartBtn.textContent = textSoldout;
  }
}
</script>